---
import ShellFooter from "../components/layout/ShellFooter.astro";
import ShellHeader from "../components/layout/ShellHeader.astro";
import {
  DEFAULT_LOCALE,
  buildLocaleAlternates,
  getLocaleMeta,
  localizePath,
  type Locale,
} from "../lib/i18n";
import {
  localizeBlossomsAssetHtml,
  toAbsoluteSiteUrl,
  toRelativeSiteUrl,
  toLocalBlossomsAssetUrl,
} from "../lib/url-utils";
import { buildSiteSchemas, DEFAULT_OG_IMAGE } from "../lib/seo";

const {
  title,
  description,
  canonical,
  bodyClass = "",
  global,
  seo = {},
  locale = DEFAULT_LOCALE,
  localizedPath,
  showLanguageSwitcher = true,
} = Astro.props;
const currentLocale = locale as Locale;

const robots = seo.robots || {};
const robotsContent = [
  robots.index || "index",
  robots.follow || "follow",
  robots["max-image-preview"] || "max-image-preview:large",
  robots["max-snippet"] || "max-snippet:-1",
  robots["max-video-preview"] || "max-video-preview:-1",
]
  .filter(Boolean)
  .join(", ");
const absoluteCanonical = canonical ? toAbsoluteSiteUrl(canonical) : undefined;
const siteSchemas = buildSiteSchemas();
const pageSchemas = Array.isArray(seo.schema)
  ? seo.schema
  : seo.schema
    ? [seo.schema]
    : [];
const combinedSchemas = [...siteSchemas, ...pageSchemas];
const siteTitle =
  global.siteTitle && global.siteTitle !== "Just a moment..."
    ? global.siteTitle
    : "Cherry Blossoms";
const fallbackBodyClass =
  "home wp-singular page-template-default page page-id-44 wp-custom-logo wp-embed-responsive wp-theme-kadence footer-on-bottom hide-focus-outline link-style-standard content-title-style-hide content-width-fullwidth content-style-unboxed content-vertical-padding-hide non-transparent-header mobile-non-transparent-header";
const resolvedBodyClass = bodyClass || global.bodyClass || fallbackBodyClass;
const fontFaceStyles = localizeBlossomsAssetHtml(
  (global.inlineStyles || []).find((css) => css.includes("@font-face")) || "",
);
const resolvedOgImage = seo.ogImage || DEFAULT_OG_IMAGE;
const resolvedTwitterImage = seo.twitterImage || resolvedOgImage;
const localeMeta = getLocaleMeta(currentLocale);
const currentPath = toRelativeSiteUrl(localizedPath || canonical || "/");
const localeAlternates = showLanguageSwitcher
  ? buildLocaleAlternates(currentPath)
  : [];
---

<!doctype html>
<html lang={localeMeta.htmlLang} class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, minimum-scale=1"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    {seo.keywords && <meta name="keywords" content={seo.keywords} />}
    <meta name="author" content="Cherry Blossoms Dating" />
    <meta name="generator" content="Astro" />
    <meta name="theme-color" content="#921b31" />
    <meta name="robots" content={robotsContent} />
    {absoluteCanonical && <link rel="canonical" href={absoluteCanonical} />}
    <meta property="og:title" content={seo.ogTitle || title} />
    <meta
      property="og:description"
      content={seo.ogDescription || description}
    />
    <meta property="og:type" content={seo.ogType || "website"} />
    <meta property="og:site_name" content="Cherry Blossoms Dating" />
    <meta property="og:locale" content={localeMeta.ogLocale} />
    {
      absoluteCanonical && (
        <meta property="og:url" content={absoluteCanonical} />
      )
    }
    {
      localeAlternates.map((alternate) => (
        <link
          rel="alternate"
          hreflang={alternate.hrefLang}
          href={toAbsoluteSiteUrl(alternate.href)}
        />
      ))
    }
    <meta property="og:image" content={resolvedOgImage} />
    <meta
      name="twitter:card"
      content={seo.twitterCard || "summary_large_image"}
    />
    <meta name="twitter:site" content="@CherryBlossomsI" />
    <meta name="twitter:title" content={seo.twitterTitle || title} />
    <meta
      name="twitter:description"
      content={seo.twitterDescription || description}
    />
    <meta name="twitter:image" content={resolvedTwitterImage} />
    <link
      rel="icon"
      href={toLocalBlossomsAssetUrl(
        "https://www.blossoms.com/wp-content/uploads/2025/02/cropped-blossoms-icon-1-150x150.png",
      )}
      sizes="32x32"
    />
    <link
      rel="icon"
      href={toLocalBlossomsAssetUrl(
        "https://www.blossoms.com/wp-content/uploads/2025/02/cropped-blossoms-icon-1-300x300.png",
      )}
      sizes="192x192"
    />
    <link
      rel="apple-touch-icon"
      href={toLocalBlossomsAssetUrl(
        "https://www.blossoms.com/wp-content/uploads/2025/02/cropped-blossoms-icon-1-300x300.png",
      )}
    />
    <style is:global>
      :root {
        color-scheme: light;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      body {
        min-height: 100vh;
      }

      body,
      button,
      input,
      textarea,
      select,
      optgroup,
      h1,
      h2,
      h3,
      h4,
      h5,
      h6,
      p,
      a,
      li,
      span,
      small,
      strong,
      label,
      figcaption,
      blockquote,
      summary {
        font-family: Arial, Helvetica, sans-serif !important;
      }

      #wrapper {
        overflow: hidden;
        overflow: clip;
      }

      body.footer-on-bottom #wrapper {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      body.footer-on-bottom #inner-wrap {
        flex: 1 0 auto;
      }

      .astro-site-content {
        display: block;
      }

      .single-content .entry-content,
      .entry-content {
        overflow-wrap: anywhere;
      }
      @media (max-width: 1024px) {
        :root {
          --global-content-edge-padding: 0rem;
        }
      }

      @media (max-width: 767px) {
        :root {
          --global-content-edge-padding: 0rem;
        }
      }
    </style>
    {fontFaceStyles && <style is:global set:html={fontFaceStyles} />}
    {
      combinedSchemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
    {
      showLanguageSwitcher && (
        <script
          is:inline
          define:vars={{
            currentLocale,
            currentPath,
            defaultLocale: DEFAULT_LOCALE,
            redirectTemplate: localizePath(currentPath, "__LOCALE__" as Locale),
          }}
        >
          const storageKey = "cb-preferred-language";
          const botPattern =
            /bot|crawler|spider|crawling|facebookexternalhit|slurp|bingpreview/i;

          if (!botPattern.test(navigator.userAgent || "")) {
            const savedLocale = window.localStorage.getItem(storageKey);

            if (currentLocale !== defaultLocale) {
              window.localStorage.setItem(storageKey, currentLocale);
            } else if (savedLocale && savedLocale !== defaultLocale) {
              const redirectHref = redirectTemplate.replace("__LOCALE__", savedLocale);
              if (redirectHref && redirectHref !== window.location.pathname) {
                window.location.replace(redirectHref);
              }
            }
          }
        </script>
      )
    }
    <script is:inline>
      document.documentElement.classList.remove("no-js");
    </script>
  </head>
  <body class={resolvedBodyClass}>
    <div id="wrapper" class="site wp-site-blocks">
      <ShellHeader
        siteTitle={siteTitle}
        locale={currentLocale}
        currentPath={currentPath}
        showLanguageSwitcher={showLanguageSwitcher}
      />
      <main
        id="inner-wrap"
        class="wrap kt-clear astro-site-content"
        role="main"
      >
        <div id="main">
          <slot />
        </div>
      </main>
      <ShellFooter locale={currentLocale} currentPath={currentPath} />
    </div>
  </body>
</html>
