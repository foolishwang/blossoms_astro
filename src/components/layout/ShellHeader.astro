---
const { siteTitle = "Cherry Blossoms" } = Astro.props;
const pathname = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

function isActivePath(href = "") {
  if (href === "/") return pathname === "/";
  if (href === "/blog/")
    return pathname === "/blog/" || pathname.startsWith("/blog/");
  if (href === "/#locations") return pathname === "/";
  return pathname === href;
}
---

<header class="cb-shell-header" role="banner">
  <div class="cb-shell-header__inner">
    <a class="cb-shell-brand" href="/" aria-label={siteTitle}>
      <img
        src="/assets/images/www-blossoms-com-logo.png"
        alt="Cherry Blossoms Dating logo"
      />
    </a>
    <button
      class="cb-shell-mobile-toggle"
      aria-label="Toggle menu"
      id="mobile-toggle"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav class="cb-shell-nav" id="main-nav" aria-label="Primary">
      <a href="/" aria-current={isActivePath("/") ? "page" : undefined}>Home</a>
      <a
        href="/about-us/"
        aria-current={isActivePath("/about-us/") ? "page" : undefined}
        >About Us</a
      >
      <a
        href="/dating-safety/"
        aria-current={isActivePath("/dating-safety/") ? "page" : undefined}
        >Dating Safety</a
      >
      <a
        href="/frequently-asked-questions/"
        aria-current={isActivePath("/frequently-asked-questions/")
          ? "page"
          : undefined}>FAQs</a
      >
      <a
        href="/#locations"
        aria-current={isActivePath("/#locations") ? "page" : undefined}
        >Locations</a
      >
      <a
        href="/blog/"
        aria-current={isActivePath("/blog/") ? "page" : undefined}>Blog</a
      >
      <div class="cb-shell-nav-actions">
        <a class="cb-shell-link" href="https://members.blossoms.com/login.php"
          >Login</a
        >
        <a
          class="cb-shell-button"
          href="https://members.blossoms.com/register.php">Register</a
        >
      </div>
    </nav>
    <div class="cb-shell-actions desktop-only">
      <a class="cb-shell-link" href="https://members.blossoms.com/login.php"
        >Login</a
      >
      <a
        class="cb-shell-button"
        href="https://members.blossoms.com/register.php">Register</a
      >
    </div>
  </div>
</header>

<script is:inline>
  const toggle = document.getElementById("mobile-toggle");
  const nav = document.getElementById("main-nav");

  if (toggle && nav) {
    toggle.addEventListener("click", () => {
      toggle.classList.toggle("is-open");
      nav.classList.toggle("is-open");
      document.body.classList.toggle("lock-scroll");
    });

    nav.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        toggle.classList.remove("is-open");
        nav.classList.remove("is-open");
        document.body.classList.remove("lock-scroll");
      });
    });
  }
</script>

<style>
  .cb-shell-header {
    position: sticky;
    top: 0;
    z-index: 40;
    border-bottom: 1px solid rgba(146, 55, 72, 0.08);
    background:
      linear-gradient(
        180deg,
        rgba(255, 251, 249, 0.97),
        rgba(255, 245, 241, 0.94)
      ),
      #fff9f7;
    box-shadow: 0 0.75rem 1.5rem rgba(109, 35, 51, 0.05);
  }

  .cb-shell-header__inner {
    width: min(1200px, calc(100% - 2rem));
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.25rem;
    align-items: center;
    min-height: 5rem;
  }

  .cb-shell-brand img {
    display: block;
    width: 15rem;
    max-width: 100%;
    height: auto;
  }

  .cb-shell-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem 1.15rem;
  }

  .cb-shell-nav a,
  .cb-shell-link {
    color: #5a2e39;
    text-decoration: none;
    font:
      600 0.96rem/1.2 Poppins,
      sans-serif;
  }

  .cb-shell-nav a:hover,
  .cb-shell-link:hover {
    color: #a42a34;
  }

  .cb-shell-nav a[aria-current="page"] {
    color: #b5303d;
  }

  .cb-shell-actions {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .cb-shell-mobile-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 1.5rem;
    height: 1.1rem;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    z-index: 50;
  }

  .cb-shell-mobile-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: #5a2e39;
    transition: all 0.3s ease;
  }

  .cb-shell-nav-actions {
    display: none;
  }

  .desktop-only {
    display: flex;
  }

  .cb-shell-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.35rem;
    padding: 0.52rem 1rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #d65258, #ab3340);
    color: #fff;
    text-decoration: none;
    font:
      600 0.89rem/1 Poppins,
      sans-serif;
    letter-spacing: 0.01em;
    box-shadow: 0 0.45rem 1rem rgba(164, 42, 52, 0.12);
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      background 0.18s ease;
  }

  .cb-shell-button:hover {
    color: #fff;
    background: linear-gradient(135deg, #c94750, #9b2f3b);
    box-shadow: 0 0.7rem 1.35rem rgba(164, 42, 52, 0.14);
    transform: translateY(-1px);
  }

  @media (max-width: 1024px) {
    :global(:root) {
      --global-content-edge-padding: 0rem;
    }

    .cb-shell-header__inner {
      grid-template-columns: auto 1fr;
      padding: 0.85rem 0;
      min-height: 4.5rem;
    }

    .cb-shell-brand img {
      width: 12rem;
    }

    .cb-shell-mobile-toggle {
      display: flex;
      justify-self: end;
    }

    .cb-shell-nav {
      position: fixed;
      top: 0;
      right: -100%;
      width: 85%;
      height: 100vh;
      padding: 6rem 2rem;
      flex-direction: column;
      justify-content: flex-start;
      align-items: flex-start;
      background: linear-gradient(180deg, #fffdfc 0%, #fff5f1 100%);
      box-shadow: -1rem 0 3rem rgba(59, 18, 29, 0.1);
      transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      z-index: 45;
    }

    .cb-shell-nav.is-open {
      right: 0;
    }

    .cb-shell-nav a {
      font-size: 1.25rem;
      width: 100%;
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(90, 46, 57, 0.08);
    }

    .cb-shell-nav-actions {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      width: 100%;
      margin-top: 2rem;
    }

    .desktop-only {
      display: none;
    }

    .cb-shell-mobile-toggle.is-open span:nth-child(1) {
      transform: translateY(0.45rem) rotate(45deg);
    }

    .cb-shell-mobile-toggle.is-open span:nth-child(2) {
      opacity: 0;
    }

    .cb-shell-mobile-toggle.is-open span:nth-child(3) {
      transform: translateY(-0.45rem) rotate(-45deg);
    }
  }

  :global(body.lock-scroll) {
    overflow: hidden !important;
  }
</style>
