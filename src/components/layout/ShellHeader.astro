---
import {
  DEFAULT_LOCALE,
  UI_STRINGS,
  getLanguageOptions,
  localizePath,
  stripLocalePrefix,
  type Locale,
} from "../../lib/i18n";

const {
  siteTitle = "Cherry Blossoms",
  locale = DEFAULT_LOCALE,
  currentPath = "/",
  showLanguageSwitcher = true,
} = Astro.props as {
  siteTitle?: string;
  locale?: Locale;
  currentPath?: string;
  showLanguageSwitcher?: boolean;
};
const pathname = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const basePathname = stripLocalePrefix(pathname);
const ui = UI_STRINGS[locale] || UI_STRINGS[DEFAULT_LOCALE];
const languageOptions = showLanguageSwitcher
  ? getLanguageOptions(currentPath)
  : [];

const navLinks = [
  { href: localizePath("/", locale), label: ui.nav.home, match: "/" },
  {
    href: localizePath("/about-us/", locale),
    label: ui.nav.about,
    match: "/about-us/",
  },
  {
    href: localizePath("/dating-safety/", locale),
    label: ui.nav.datingSafety,
    match: "/dating-safety/",
  },
  {
    href: localizePath("/frequently-asked-questions/", locale),
    label: ui.nav.faqs,
    match: "/frequently-asked-questions/",
  },
  {
    href: localizePath("/#locations", locale),
    label: ui.nav.locations,
    match: "/#locations",
  },
  { href: "/blog/", label: ui.nav.blog, match: "/blog/" },
];

function isActivePath(href = "") {
  if (href === "/") return basePathname === "/";
  if (href === "/blog/")
    return basePathname === "/blog/" || basePathname.startsWith("/blog/");
  if (href === "/#locations") return basePathname === "/";
  return basePathname === href;
}
---

<header class="cb-shell-header" role="banner">
  <div class="cb-shell-header__inner">
    <a class="cb-shell-brand" href="/" aria-label={siteTitle}>
      <img
        src="/assets/images/www-blossoms-com-logo.png"
        alt="Cherry Blossoms Dating logo"
      />
    </a>
    <button
      class="cb-shell-mobile-toggle"
      aria-label="Toggle menu"
      id="mobile-toggle"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav class="cb-shell-nav" id="main-nav" aria-label="Primary">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={isActivePath(link.match) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
      <div class="cb-shell-nav-actions">
        {
          showLanguageSwitcher && (
            <label class="cb-language-picker cb-language-picker--mobile">
              <select data-language-switcher>
                {languageOptions.map((option) => (
                  <option
                    value={option.href}
                    selected={option.locale === locale}
                  >
                    {option.nativeLabel}
                  </option>
                ))}
              </select>
            </label>
          )
        }
        <a class="cb-shell-link" href="https://members.blossoms.com/login.php"
          >{ui.nav.login}</a
        >
        <a
          class="cb-shell-button"
          href="https://members.blossoms.com/register.php">{ui.nav.register}</a
        >
      </div>
    </nav>
    <div class="cb-shell-actions desktop-only">
      {
        showLanguageSwitcher && (
          <label class="cb-language-picker">
            <select data-language-switcher>
              {languageOptions.map((option) => (
                <option value={option.href} selected={option.locale === locale}>
                  {option.nativeLabel}
                </option>
              ))}
            </select>
          </label>
        )
      }
      <a class="cb-shell-link" href="https://members.blossoms.com/login.php"
        >{ui.nav.login}</a
      >
      <a
        class="cb-shell-button"
        href="https://members.blossoms.com/register.php">{ui.nav.register}</a
      >
    </div>
  </div>
</header>

<script is:inline>
  const languageStorageKey = "cb-preferred-language";
  const toggle = document.getElementById("mobile-toggle");
  const nav = document.getElementById("main-nav");
  const languageSwitchers = document.querySelectorAll(
    "[data-language-switcher]",
  );

  languageSwitchers.forEach((select) => {
    select.addEventListener("change", (event) => {
      const target = event.currentTarget;
      if (!(target instanceof HTMLSelectElement)) return;
      const nextHref = target.value;
      const localeMatch = nextHref.match(/^\/([a-z-]+)\//i);
      const nextLocale = (localeMatch && localeMatch[1]) || "en";
      window.localStorage.setItem(languageStorageKey, nextLocale);
      window.location.href = nextHref;
    });
  });

  if (toggle && nav) {
    toggle.addEventListener("click", () => {
      toggle.classList.toggle("is-open");
      nav.classList.toggle("is-open");
      document.body.classList.toggle("lock-scroll");
    });

    nav.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        toggle.classList.remove("is-open");
        nav.classList.remove("is-open");
        document.body.classList.remove("lock-scroll");
      });
    });
  }
</script>

<style>
  .hide {
    display: none !important;
  }
  .cb-shell-header {
    position: sticky;
    top: 0;
    z-index: 40;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    border-bottom: 1px solid rgba(146, 55, 72, 0.08);
    background:
      linear-gradient(
        180deg,
        rgba(255, 251, 249, 0.97),
        rgba(255, 245, 241, 0.94)
      ),
      #fff9f7;
    box-shadow: 0 0.75rem 1.5rem rgba(109, 35, 51, 0.05);
  }

  .cb-shell-header__inner {
    width: min(1200px, calc(100% - 2rem));
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.25rem;
    align-items: center;
    min-height: 5rem;
  }

  .cb-shell-brand img {
    display: block;
    width: 250px;
    max-width: 100%;
    height: auto;
  }

  .cb-shell-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem 1.15rem;
  }

  .cb-shell-nav a,
  .cb-shell-link {
    color: #5a2e39;
    text-decoration: none;
    font:
      600 0.96rem/1.2 Poppins,
      sans-serif;
  }

  .cb-shell-nav a:hover,
  .cb-shell-link:hover {
    color: #a42a34;
  }

  .cb-shell-nav a[aria-current="page"] {
    color: #b5303d;
  }

  .cb-shell-actions {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .cb-language-picker {
    display: inline-flex;
  }

  .cb-language-picker select {
    min-height: 2.15rem;
    padding: 0.42rem 2rem 0.42rem 0.75rem;
    border: 1px solid rgba(164, 42, 52, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.96);
    color: #5a2e39;
    font:
      600 0.82rem/1.1 Poppins,
      sans-serif;
  }

  .cb-shell-mobile-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 1.5rem;
    height: 1.1rem;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    z-index: 50;
  }

  .cb-shell-mobile-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: #5a2e39;
    transition: all 0.3s ease;
  }

  .cb-shell-nav-actions {
    display: none;
  }

  .desktop-only {
    display: flex;
  }

  .cb-shell-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.15rem;
    padding: 0.42rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(164, 42, 52, 0.18);
    background: #c84a55;
    color: #fff;
    text-decoration: none;
    font:
      600 0.86rem/1 Poppins,
      sans-serif;
    letter-spacing: 0;
    transition:
      transform 0.18s ease,
      background 0.18s ease,
      border-color 0.18s ease;
  }

  .cb-shell-button:hover {
    color: #fff;
    background: #b93d49;
    border-color: rgba(164, 42, 52, 0.28);
    transform: translateY(-1px);
  }

  @media (max-width: 1024px) {
    :global(:root) {
      --global-content-edge-padding: 0rem;
    }

    .cb-shell-header {
      overflow-x: clip;
    }

    .cb-shell-header__inner {
      grid-template-columns: auto 1fr;
      padding: 0.85rem 0;
      min-height: 4.5rem;
    }

    .cb-shell-brand img {
      width: 250px;
    }

    .cb-shell-mobile-toggle {
      display: flex;
      justify-self: end;
    }

    .cb-shell-nav {
      position: fixed;
      top: 0;
      right: -100%;
      width: 70%;
      height: 100vh;
      padding: 6rem 2rem;
      flex-direction: column;
      justify-content: flex-start;
      align-items: flex-start;
      background: linear-gradient(180deg, #fffdfc 0%, #fff5f1 100%);
      box-shadow: -1rem 0 3rem rgba(59, 18, 29, 0.1);
      transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      z-index: 45;
    }

    .cb-shell-nav.is-open {
      right: 0;
    }

    .cb-shell-nav a {
      font-size: 1.25rem;
      width: 100%;
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(90, 46, 57, 0.08);
    }

    .cb-shell-nav-actions {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      width: 100%;
      margin-top: 2rem;
    }

    .cb-language-picker,
    .cb-language-picker select {
      width: 100%;
    }

    .cb-language-picker__label {
      font-size: 0.72rem;
    }

    .desktop-only {
      display: none;
    }

    .cb-shell-mobile-toggle.is-open span:nth-child(1) {
      transform: translateY(0.45rem) rotate(45deg);
    }

    .cb-shell-mobile-toggle.is-open span:nth-child(2) {
      opacity: 0;
    }

    .cb-shell-mobile-toggle.is-open span:nth-child(3) {
      transform: translateY(-0.45rem) rotate(-45deg);
    }
  }

  @media (max-width: 640px) {
    .cb-shell-header__inner {
      width: 100%;
      max-width: 100%;
      min-height: 2.4rem;
      padding: 0.4rem 0.75rem;
      gap: 0.75rem;
      grid-template-columns: minmax(0, 1fr) auto;
      box-sizing: border-box;
    }

    .cb-shell-brand img {
      width: 240px;
    }

    .cb-shell-mobile-toggle {
      width: 1.35rem;
      height: 0.95rem;
      position: static;
    }
  }

  :global(body.lock-scroll) {
    overflow: hidden !important;
  }
</style>
