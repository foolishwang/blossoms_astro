---
import BlogCard from "./BlogCard.astro";

type BlogIndexPost = {
  title: string;
  href: string;
  excerpt: string;
  date?: string | null;
  image?: string | null;
};

const {
  description,
  posts,
  eyebrow = "Blossoms Journal",
  title = "Dating advice, safety guidance, and real relationship stories.",
} = Astro.props as {
  description: string;
  posts: BlogIndexPost[];
  eyebrow?: string;
  title?: string;
};
---

<section class="blog-index">
  <div class="blog-index__shell">
    <div class="blog-index__hero">
      <p class="blog-index__eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="blog-index__lede">{description}</p>
    </div>

    <div class="blog-index__grid">
      {posts.map((post) => <BlogCard {...post} />)}
    </div>
  </div>
</section>

<style>
  .blog-index {
    padding: 4.5rem 0 5.5rem;
    background:
      radial-gradient(
        circle at top left,
        rgba(233, 118, 93, 0.12),
        transparent 28rem
      ),
      linear-gradient(180deg, #fff9f6 0%, #fffdfc 100%);
  }

  .blog-index__shell {
    width: min(1220px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .blog-index__hero {
    margin-bottom: 2.5rem;
    text-align: center;
    justify-items: center;
  }

  .blog-index__eyebrow {
    margin: 0 0 0.75rem;
    color: #a42a34;
    font:
      700 0.8rem/1.2 Poppins,
      sans-serif;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .blog-index h1 {
    margin: 0;
    color: #24161c;
    font-size: clamp(1.32rem, 2.88vw, 2.88rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
  }

  .blog-index__lede {
    margin: 1.1rem 0 0;
    max-width: 40rem;
    color: #67545b;
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .blog-index__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.4rem;
  }

  @media (max-width: 980px) {
    .blog-index__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .blog-index {
      padding: 3.5rem 0 4rem;
    }

    .blog-index__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
