---
const next = Astro.url.searchParams.get("next") || "/admin/posts/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Login</title>
  </head>
  <body>
    <main class="login-page">
      <section class="login-card">
        <p class="login-kicker">Blossoms Admin</p>
        <h1>Sign in to manage posts</h1>
        <p class="login-copy">
          Use the admin credentials to edit blog posts, upload images, and
          publish updates.
        </p>

        <form id="login-form" class="login-form" data-next={next}>
          <label>
            <span>Username</span>
            <input
              name="username"
              value="admin"
              autocomplete="username"
              required
            />
          </label>
          <label>
            <span>Password</span>
            <input
              name="password"
              type="password"
              autocomplete="current-password"
              required
            />
          </label>
          <button id="login-submit" type="submit">Sign In</button>
          <p id="login-error" class="login-error" hidden></p>
        </form>
      </section>
    </main>

    <script src="../scripts/login-page.ts"></script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
  }
  body {
    margin: 0;
    font-family: Poppins, sans-serif;
    background:
      radial-gradient(
        circle at top,
        rgba(244, 67, 54, 0.18),
        transparent 28rem
      ),
      linear-gradient(180deg, #fff8f4 0%, #fffdfc 100%);
    color: #24161c;
  }
  .login-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem;
  }
  .login-card {
    width: min(30rem, 100%);
    padding: 2rem;
    border: 1px solid rgba(125, 58, 66, 0.12);
    border-radius: 1.75rem;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 1.4rem 3rem rgba(121, 57, 67, 0.12);
  }
  .login-kicker {
    margin: 0 0 0.75rem;
    color: #a42a34;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  h1 {
    margin: 0;
    font:
      700 clamp(2rem, 6vw, 3rem) / 0.95 Raleway,
      serif;
    letter-spacing: -0.04em;
  }
  .login-copy {
    margin: 1rem 0 0;
    color: #6c5860;
    line-height: 1.75;
  }
  .login-form {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }
  .login-form label {
    display: grid;
    gap: 0.45rem;
  }
  .login-form span {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6c5860;
  }
  .login-form input {
    width: 100%;
    padding: 0.95rem 1rem;
    border: 1px solid rgba(125, 58, 66, 0.16);
    border-radius: 999px;
    background: #fff;
    font: inherit;
  }
  .login-form button {
    border: 0;
    border-radius: 999px;
    padding: 1rem 1.2rem;
    background: linear-gradient(135deg, #c72d39 0%, #e34c55 100%);
    color: #fff;
    font:
      700 1rem/1 Poppins,
      sans-serif;
    cursor: pointer;
  }
  .login-form button[disabled] {
    opacity: 0.7;
    cursor: wait;
  }
  .login-error {
    margin: 0;
    color: #a42a34;
  }
</style>
