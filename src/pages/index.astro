    </section>

    <section class="locations shell" id="locations">
      <div class="locations__intro">
        <p class="section-kicker">Coverage</p>
        <h2>
          Explore Philippines city pages for people specifically looking for
          Filipina dating by location
        </h2>
      </div>

      <div class="locations__popular">
        {
          popularCities.map((city) => (
            <a class="locations__pill" href={city.href}>
              {city.label}
            </a>
