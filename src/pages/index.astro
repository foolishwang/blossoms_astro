        </p>
        <div class="panel-actions">
          <a class="button-primary" href="/blog/">Read the Journal</a>
          <a class="button-secondary" href="/frequently-asked-questions/">
            Browse FAQs
          </a>
        </div>
        <a
          class="store-badge"
          href="https://play.google.com/store/apps/details?id=com.cherryblossoms.dating&pli=1"
        >
          <img
            src={toLocalBlossomsAssetUrl(
              "https://www.blossoms.com/wp-content/uploads/2025/03/get-blossoms-asian-dating-app-in-play-store.png",
            )}
            alt="Get Blossoms Asian dating app in Play Store"
            loading="lazy"
            decoding="async"
          />
        </a>
      </div>

      <div class="stories__cards">
        <h3>Success Stories</h3>
        {
          testimonials.map((story) => (
            <a class="story-card" href={story.href}>
              <img
                src={story.image}
                alt={story.name}
                loading="lazy"
                decoding="async"
              />
              <div class="story-card__body">
                <p>{story.quote}</p>
                <strong>{story.name}</strong>
              </div>
            </a>
