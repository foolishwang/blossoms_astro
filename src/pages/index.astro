            <li>Real members worldwide</li>
            <li>Designed for long-term relationships</li>
          </ul>
        </div>

        <aside class="hero__panel">
          <div class="hero__badge">🌸 Start Your Journey</div>
          <a
            class="cta cta--male"
            href="https://members.blossoms.com/register.php?gender=male&adid=www"
            target="_blank"
            rel="noreferrer noopener"
          >
            <span>I Am a Man...</span>
            <small>Seeking a Meaningful Relationship</small>
          </a>
          <a
            class="cta cta--female"
            href="https://members.blossoms.com/register.php?gender=female&adid=www"
            target="_blank"
            rel="noreferrer noopener"
          >
