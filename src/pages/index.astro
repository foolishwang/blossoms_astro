    <section class="pillars shell">
      <div class="pillars__intro">
        <p class="section-kicker">Core Reasons</p>
        <h2>Why people choose Blossoms for serious dating</h2>
      </div>

      <div class="pillars__tabs" data-pillars>
        <div
          class="pillars__nav"
          role="tablist"
          aria-label="Homepage value panels"
        >
          {
            pillars.map((pillar, index) => (
              <button
                class="pillars__tab"
                type="button"
                role="tab"
                id={`tab-${pillar.id}`}
                aria-controls={`panel-${pillar.id}`}
                aria-selected={index === 0 ? "true" : "false"}
                tabindex={index === 0 ? "0" : "-1"}
                data-pillars-tab
              >
                {pillar.tab}
              </button>
            ))
          }
        </div>

        <div class="pillars__panels">
          {
            pillars.map((pillar, index) => (
              <article
                class:list={["pillar-panel", index === 0 && "is-active"]}
                role="tabpanel"
                id={`panel-${pillar.id}`}
                aria-labelledby={`tab-${pillar.id}`}
                hidden={index === 0 ? undefined : true}
                data-pillars-panel
              >
                <div class="stack">
                  <h3>{pillar.title}</h3>
                  <p>{pillar.body}</p>
                  {pillar.id === "using" && (
                    <div class="panel-actions">
                      <a
                        class="button-primary"
                        href="https://members.blossoms.com/register.php"
                        rel="nofollow"
                      >
                        Join Us
                      </a>
                      <a
                        class="button-secondary"
                        href="https://members.blossoms.com/login.php"
                        rel="nofollow"
                      >
                        Login
                      </a>
                    </div>
                  )}
                </div>
                <div class="pillar-panel__art" aria-hidden="true">
                  <div class={`orb orb--${pillar.id}`} />
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="stories shell">
      <div class="stories__intro">
        <p class="section-kicker">Real People, Real Love</p>
        <h2>Relationship stories from a long-running Asian dating community</h2>
        <p>
          Your journey to love should feel exciting and worry-free. Blossoms
          prioritizes safety with verified profiles and privacy protection,
          while helping you meet the right person with far more confidence than
