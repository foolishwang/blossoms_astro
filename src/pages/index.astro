      </div>

      <details class="locations__disclosure">
        <summary>Browse supported cities and provinces</summary>
        <div class="locations__grid">
          {
            locations.map((group) => (
              <article class="location-card">
                <h3>{group.province}</h3>
                <ul>
                  {group.cities.map((city) => (
                    <li>
                      <a href={city.href}>{city.label}</a>
