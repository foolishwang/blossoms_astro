---
import routes from "../data/routes.json";
import global from "../data/global.json";
import SiteLayout from "../layouts/SiteLayout.astro";
import { toLocalBlossomsAssetUrl, toRelativeSiteUrl } from "../lib/url-utils";
import {
  buildBreadcrumbSchema,
  buildItemListSchema,
  buildWebPageSchema,
} from "../lib/seo";

const home = routes.find((entry) => entry.route === "/");

if (!home) {
  throw new Error("Homepage route not found in routes.json");
}

function decodeHtml(value = "") {
  return value
    .replaceAll("&#038;", "&")
    .replaceAll("&#8211;", "–")
    .replaceAll("&#8217;", "'")
    .replaceAll("&#8220;", '"')
    .replaceAll("&#8221;", '"')
    .replaceAll("&#8230;", "...")
    .replaceAll("&amp;", "&")
    .replaceAll("&quot;", '"')
    .replaceAll("&#039;", "'");
}

function stripTags(value = "") {
  return decodeHtml(
    value
      .replace(/<[^>]+>/g, " ")
      .replace(/\s+/g, " ")
      .trim(),
  );
}

function extractTestimonials(content = "") {
  return [
    ...content.matchAll(
      /<blockquote class="kt-testimonial-content"><a href="([^"]+)">([\s\S]*?)<\/a><\/blockquote>[\s\S]*?<div class="kt-testimonial-name"><strong>([\s\S]*?)<\/strong><\/div>/g,
    ),
  ].map((match, index) => ({
    href: toRelativeSiteUrl(match[1]),
    quote: stripTags(match[2]),
    name: decodeHtml(match[3]),
    image:
      [
        "https://www.blossoms.com/wp-content/uploads/2025/02/location1-dating-site-online-couple-david-and-phoebe.png",
        "https://www.blossoms.com/wp-content/uploads/2025/02/location1-dating-site-online-couple-john-and-sienna.png",
        "https://www.blossoms.com/wp-content/uploads/2025/02/location1-dating-site-online-couple-doug-and-jheng.png",
      ].map((url) => toLocalBlossomsAssetUrl(url))[index] || "",
  }));
}

function extractFaqItems(content = "") {
  return [
    ...content.matchAll(
      /<span class="kt-blocks-accordion-title">([\s\S]*?)<\/span>[\s\S]*?<div class="kt-accordion-panel-inner">[\s\S]*?<p[^>]*>([\s\S]*?)<\/p>/g,
    ),
  ].map((match) => ({
    question: stripTags(match[1]),
    answer: stripTags(match[2]),
  }));
}

function extractLocations(content = "") {
  const sectionMatch = content.match(
    /<ul class="containerx">([\s\S]*?)<\/ul>\s*<style>/,
  );
  if (!sectionMatch) return [];

  return [
    ...sectionMatch[1].matchAll(
      /<li class="cardx"><strong>([\s\S]*?)<\/strong><ul class='list-unstyled'>([\s\S]*?)<\/ul><\/li>/g,
    ),
  ].map((match) => ({
    province: stripTags(match[1]),
    cities: [
      ...match[2].matchAll(
        /<a href="([^"]+)"[^>]*title="([^"]+)">([\s\S]*?)<\/a>/g,
      ),
    ].map((cityMatch) => ({
      href: toRelativeSiteUrl(cityMatch[1]),
      title: cityMatch[2],
      label: stripTags(cityMatch[3]),
    })),
  }));
}

const testimonials = extractTestimonials(home.content);
const faqItems = extractFaqItems(home.content);
const locations = extractLocations(home.content);
const popularCities = locations.flatMap((group) => group.cities).slice(0, 18);

const featuredLogos = [
  {
    src: toLocalBlossomsAssetUrl(
      "https://www.blossoms.com/wp-content/uploads/2025/02/fox-news-asian-dating-site-philippines-review.png",
    ),
    alt: "Fox News asian dating site Philippines review",
  },
  {
    src: toLocalBlossomsAssetUrl(
      "https://www.blossoms.com/wp-content/uploads/2025/02/yahoo-news-philippines-dating-site-review.png",
    ),
    alt: "Yahoo News Philippines dating site review",
  },
  {
    src: toLocalBlossomsAssetUrl(
      "https://www.blossoms.com/wp-content/uploads/2025/02/bloomberg-philippines-dating-website-reviews.png",
    ),
    alt: "Bloomberg Philippines dating website reviews",
  },
];

const trustPoints = [
  "Undefeated Champions of Asian Dating. Over 50 years of match-making success and proven results.",
  "Exclusive free access for Asian women to keep the community active, balanced, and genuine.",
  "Advanced security technology with profile validation and privacy safeguards.",
];

const stats = [
  {
    value: "86%",
    label: "User Engagement",
    description: "Of actively engaged chats within 24 hours of joining.",
  },
  {
    value: "5M",
    label: "Perfect Match",
    description: "Successful matches made since the platform's launch.",
  },
  {
    value: "34K+",
    label: "Love Online",
    description: "Messages exchanged daily on the platform on average.",
  },
];

const pillars = [
  {
    id: "different",
    tab: "Why We're Different",
    title:
      "Why Blossoms feels different from faster, lower-trust dating platforms",
    body: "Blossoms is built around trust signals that matter in Asian dating: profile verification, safer messaging, a longer operating history, and a member base oriented toward real relationships instead of disposable attention loops.",
  },
  {
    id: "using",
    tab: "Using Blossoms.com",
    title: "A long-running Asian dating brand with clearer expectations",
    body: "Finding the right Asian dating site can be difficult when most platforms optimize for noise. Blossoms takes a more deliberate route, pairing decades of matchmaking experience with a product shaped around sincerity, safety, and long-term intent.",
  },
  {
    id: "love",
    tab: "Long-Term Love",
    title: "Meet Asian singles in a setting built for long-term relationships",
    body: "Cherry Blossoms supports international dating for people looking for something serious. Whether your focus is Asian dating broadly or Filipina dating in specific city pages, the platform is structured around meaningful connection rather than casual swiping.",
  },
];

const bodyClass =
  global.bodyClass ||
  "home wp-singular page-template-default page page-id-44 wp-custom-logo wp-embed-responsive wp-theme-kadence footer-on-bottom hide-focus-outline link-style-standard content-title-style-hide content-width-fullwidth content-style-unboxed content-vertical-padding-hide non-transparent-header mobile-non-transparent-header";
const homeTitle =
  "Cherry Blossoms Asian Dating | International Asian Dating Since 1974";
const homeDescription =
  "Cherry Blossoms is an Asian dating site for people seeking meaningful international relationships. Discover Asian dating, real members, and long-term connections since 1974.";
const homeSchema = [
  buildWebPageSchema({
    title: homeTitle,
    description: homeDescription,
    url: "/",
  }),
  buildItemListSchema({
    name: "Popular Filipina dating cities",
    url: "/#locations",
    items: popularCities.map((city) => ({
      name: city.label,
      url: city.href,
    })),
  }),
  buildBreadcrumbSchema([{ name: "Home", url: "/" }]),
];
---

<SiteLayout
  title={homeTitle}
  description={homeDescription}
  canonical={toRelativeSiteUrl(home.link)}
  bodyClass={bodyClass}
  global={global}
  seo={{
    ...(home.seo || {}),
    title: homeTitle,
    description: homeDescription,
    ogTitle: "Cherry Blossoms | Asian Dating Since 1974",
    ogDescription: homeDescription,
    twitterTitle: "Cherry Blossoms | Asian Dating Since 1974",
    twitterDescription: homeDescription,
    schema: homeSchema,
  }}
  disableExternalAssets={true}
>
  <div class="home-redesign">
    <section class="hero">
      <div class="hero__backdrop"></div>
      <div class="shell hero__grid">
        <div class="hero__copy">
          <p class="eyebrow">Asian Dating Since 1974</p>
