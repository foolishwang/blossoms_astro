            </p>
          </div>
        </div>

        <div class="overview-card__media">
          <div class="image-card image-card--overview">
            <img
              src={toLocalBlossomsAssetUrl(
                "https://www.blossoms.com/wp-content/uploads/2025/02/blossoms-dating-site-philippines-members.jpg",
              )}
              alt="Asian online dating site in the Philippines"
              loading="lazy"
              decoding="async"
            />
            <div class="overview-card__caption">
              <span>Editorial Selection</span>
              <strong
