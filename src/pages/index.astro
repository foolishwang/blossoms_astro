            ))
          }
        </div>
      </details>
    </section>
  </div>

  <script is:inline src="https://embed.cloudflarestream.com/embed/sdk.latest.js"
  ></script>

  <script is:inline>
    (() => {
      const root = document.querySelector("[data-pillars]");
      if (!root) return;

      const tabs = Array.from(root.querySelectorAll("[data-pillars-tab]"));
      const panels = Array.from(root.querySelectorAll("[data-pillars-panel]"));

      const activate = (index) => {
        tabs.forEach((tab, tabIndex) => {
          tab.setAttribute(
            "aria-selected",
            tabIndex === index ? "true" : "false",
          );
          tab.setAttribute("tabindex", tabIndex === index ? "0" : "-1");
        });

        panels.forEach((panel, panelIndex) => {
          panel.classList.toggle("is-active", panelIndex === index);
          panel.hidden = panelIndex !== index;
        });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => activate(index));
        tab.addEventListener("keydown", (event) => {
          if (event.key !== "ArrowRight" && event.key !== "ArrowLeft") return;
          event.preventDefault();
          const nextIndex =
            event.key === "ArrowRight"
              ? (index + 1) % tabs.length
              : (index - 1 + tabs.length) % tabs.length;
          activate(nextIndex);
          tabs[nextIndex]?.focus();
        });
      });
    })();

    (() => {
      const iframe = document.getElementById("home-stream-player");
      const button = document.querySelector("[data-home-video-toggle]");
      const label = document.querySelector("[data-home-video-toggle-label]");
      if (!iframe || !button || !label) return;

      let player = null;
      let isMuted = true;

      const syncButton = () => {
        button.setAttribute("aria-pressed", String(!isMuted));
        button.classList.toggle("is-active", !isMuted);
        label.textContent = isMuted ? "Sound" : "Mute";
      };

      const setupPlayer = () => {
        if (typeof window.Stream !== "function") return false;
        player = window.Stream(iframe);
        player.muted = true;
        player.loop = true;
        syncButton();

        button.addEventListener("click", async () => {
          if (!player) return;
          try {
            isMuted = !isMuted;
            player.muted = isMuted;
            if (!isMuted) {
              player.volume = 1;
              await player.play();
            }
            syncButton();
          } catch (_error) {
            isMuted = true;
            player.muted = true;
            syncButton();
          }
        });

        return true;
      };

      if (setupPlayer()) return;

      const waitForSdk = window.setInterval(() => {
        if (!setupPlayer()) return;
        window.clearInterval(waitForSdk);
      }, 150);

      window.setTimeout(() => window.clearInterval(waitForSdk), 5000);
    })();
  </script>

  <style>
    .home-redesign {
      --bg: #fff8f3;
      --surface: rgba(255, 255, 255, 0.82);
      --surface-strong: #ffffff;
      --line: rgba(125, 58, 66, 0.12);
      --ink: #24161c;
      --muted: #67545b;
      --accent: #df4b4b;
      --accent-deep: #a42a34;
      --accent-soft: #ffe0df;
      --gold: #e6ae62;
      background: rgba(255, 255, 255, 0.25);
      color: var(--ink);
    }

    .home-redesign a {
      color: inherit;
      text-decoration: none;
    }

    .shell {
      width: min(1200px, calc(100% - 2rem));
      margin: 0 auto;
    }

    .stack {
      display: grid;
      gap: 1rem;
    }

    .section-kicker,
    .eyebrow {
      margin: 0;
      color: var(--accent-deep);
      font-family:
        "Inter",
        system-ui,
        -apple-system,
        sans-serif;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
    }

    .section-kicker::before {
