---
import routes from "../data/routes.json";
import global from "../data/global.json";
import SiteLayout from "../layouts/SiteLayout.astro";
import { DEFAULT_LOCALE, UI_STRINGS, localizePath, type Locale } from "../lib/i18n";
import { HOME_PAGE_COPY } from "../lib/home-page-copy";
import { toLocalBlossomsAssetUrl, toRelativeSiteUrl } from "../lib/url-utils";
import {
  buildBreadcrumbSchema,
  buildItemListSchema,
  buildWebPageSchema,
} from "../lib/seo";

const home = routes.find((entry) => entry.route === "/");
const {
  locale = DEFAULT_LOCALE,
  localizedPath = "/",
} = Astro.props as {
  locale?: Locale;
  localizedPath?: string;
};
const ui = UI_STRINGS[locale] || UI_STRINGS[DEFAULT_LOCALE];
const homeCopy = HOME_PAGE_COPY[locale] || HOME_PAGE_COPY[DEFAULT_LOCALE];

if (!home) {
  throw new Error("Homepage route not found in routes.json");
}

function decodeHtml(value = "") {
  return value
    .replaceAll("&#038;", "&")
    .replaceAll("&#8211;", "–")
    .replaceAll("&#8217;", "'")
    .replaceAll("&#8220;", '"')
    .replaceAll("&#8221;", '"')
    .replaceAll("&#8230;", "...")
    .replaceAll("&amp;", "&")
    .replaceAll("&quot;", '"')
    .replaceAll("&#039;", "'");
}

function stripTags(value = "") {
  return decodeHtml(
    value
      .replace(/<[^>]+>/g, " ")
      .replace(/\s+/g, " ")
      .trim(),
  );
}

function extractTestimonials(content = "") {
  return [
    ...content.matchAll(
      /<blockquote class="kt-testimonial-content"><a href="([^"]+)">([\s\S]*?)<\/a><\/blockquote>[\s\S]*?<div class="kt-testimonial-name"><strong>([\s\S]*?)<\/strong><\/div>/g,
    ),
  ].map((match, index) => ({
    href: toRelativeSiteUrl(match[1]),
    quote: stripTags(match[2]),
    name: decodeHtml(match[3]),
    image:
      [
        "https://www.blossoms.com/wp-content/uploads/2025/02/location1-dating-site-online-couple-david-and-phoebe.png",
        "https://www.blossoms.com/wp-content/uploads/2025/02/location1-dating-site-online-couple-john-and-sienna.png",
        "https://www.blossoms.com/wp-content/uploads/2025/02/location1-dating-site-online-couple-doug-and-jheng.png",
      ].map((url) => toLocalBlossomsAssetUrl(url))[index] || "",
  }));
}

function extractFaqItems(content = "") {
  return [
    ...content.matchAll(
      /<span class="kt-blocks-accordion-title">([\s\S]*?)<\/span>[\s\S]*?<div class="kt-accordion-panel-inner">[\s\S]*?<p[^>]*>([\s\S]*?)<\/p>/g,
    ),
  ].map((match) => ({
    question: stripTags(match[1]),
    answer: stripTags(match[2]),
  }));
}

function extractLocations(content = "") {
  const sectionMatch = content.match(
    /<ul class="containerx">([\s\S]*?)<\/ul>\s*<style>/,
  );
  if (!sectionMatch) return [];

  return [
    ...sectionMatch[1].matchAll(
      /<li class="cardx"><strong>([\s\S]*?)<\/strong><ul class='list-unstyled'>([\s\S]*?)<\/ul><\/li>/g,
    ),
  ].map((match) => ({
    province: stripTags(match[1]),
    cities: [
      ...match[2].matchAll(
        /<a href="([^"]+)"[^>]*title="([^"]+)">([\s\S]*?)<\/a>/g,
      ),
    ].map((cityMatch) => ({
      href: toRelativeSiteUrl(cityMatch[1]),
      title: cityMatch[2],
      label: stripTags(cityMatch[3]),
    })),
  }));
}

const extractedTestimonials = extractTestimonials(home.content);
const testimonials = homeCopy.testimonials.map((item, index) => ({
  ...extractedTestimonials[index],
  quote: item.quote,
  name: item.name,
}));
const faqItems = homeCopy.faqItems;
const locations = extractLocations(home.content);
const popularCities = locations.flatMap((group) => group.cities).slice(0, 18);

const featuredLogos = [
  {
    src: toLocalBlossomsAssetUrl(
      "https://www.blossoms.com/wp-content/uploads/2025/02/fox-news-asian-dating-site-philippines-review.png",
    ),
    alt: "Fox News asian dating site Philippines review",
  },
  {
    src: toLocalBlossomsAssetUrl(
      "https://www.blossoms.com/wp-content/uploads/2025/02/yahoo-news-philippines-dating-site-review.png",
    ),
    alt: "Yahoo News Philippines dating site review",
  },
  {
    src: toLocalBlossomsAssetUrl(
      "https://www.blossoms.com/wp-content/uploads/2025/02/bloomberg-philippines-dating-website-reviews.png",
    ),
    alt: "Bloomberg Philippines dating website reviews",
  },
];

const stats = homeCopy.statCards;
const pillars = homeCopy.pillars;

const bodyClass =
  global.bodyClass ||
  "home wp-singular page-template-default page page-id-44 wp-custom-logo wp-embed-responsive wp-theme-kadence footer-on-bottom hide-focus-outline link-style-standard content-title-style-hide content-width-fullwidth content-style-unboxed content-vertical-padding-hide non-transparent-header mobile-non-transparent-header";
const homeTitle = ui.seo.homeTitle;
const homeDescription = ui.seo.homeDescription;
const homeSchema = [
  buildWebPageSchema({
    title: homeTitle,
    description: homeDescription,
    url: localizedPath,
  }),
  buildItemListSchema({
    name: homeCopy.locationsTitle,
    url: localizePath("/#locations", locale),
    items: popularCities.map((city) => ({
      name: city.label,
      url: city.href,
    })),
  }),
  buildBreadcrumbSchema([{ name: ui.nav.home, url: localizedPath }]),
];
---

<SiteLayout
  title={homeTitle}
  description={homeDescription}
  canonical={toRelativeSiteUrl(localizedPath)}
  bodyClass={bodyClass}
  global={global}
  locale={locale}
  localizedPath={localizedPath}
  seo={{
    ...(home.seo || {}),
    title: homeTitle,
    description: homeDescription,
    keywords: ui.seo.homeKeywords,
    ogTitle: homeTitle,
    ogDescription: homeDescription,
    twitterTitle: homeTitle,
    twitterDescription: homeDescription,
    schema: homeSchema,
  }}
  disableExternalAssets={true}
>
  <div class="home-redesign">
    <section class="hero hero-section">
      <div class="hero__backdrop"></div>
      <div class="shell hero__grid">
        <aside class="cb-hero-box">
          <h2 class="cb-hero-title">🌸 {ui.home.badge}</h2>
          <a
            class="cb-btn cb-btn-male"
            href="https://members.blossoms.com/register.php?gender=male&adid=www"
            target="_blank"
            rel="noreferrer noopener"
          >
            <span class="cb-line1">{ui.home.manTitle}</span>
            <span class="cb-line2">{ui.home.manBody}</span>
          </a>
          <a
            class="cb-btn cb-btn-female"
            href="https://members.blossoms.com/register.php?gender=female&adid=www"
            target="_blank"
            rel="noreferrer noopener"
          >
            <span class="cb-line1">{ui.home.womanTitle}</span>
            <span class="cb-line2">{ui.home.womanBody}</span>
          </a>
          <div class="cb-trust">
            ✓ {ui.home.trustOne}<br />
            ✓ {ui.home.trustTwo}
          </div>
          <div class="cb-login">
            <strong>
              {ui.home.alreadyMember}
              <a href="https://members.blossoms.com/login.php">{ui.nav.login}</a>
            </strong>
          </div>
        </aside>
      </div>
    </section>

    <section class="featured shell">
      <p class="section-kicker">{homeCopy.featuredKicker}</p>
      <h2>{homeCopy.featuredTitle}</h2>
      <div class="featured__logos">
        {
          featuredLogos.map((logo) => (
            <div class="featured__logo">
              <img
                src={logo.src}
                alt={logo.alt}
                loading="lazy"
                decoding="async"
              />
            </div>
          ))
        }
      </div>
    </section>

    <section class="shell split--media">
      <div class="video-hero">
        <div class="video-hero__frame">
          <video
            id="home-stream-player"
            class="video-hero__media"
            src={toLocalBlossomsAssetUrl(
              "https://www.blossoms.com/wp-content/uploads/2025/06/AboutUsBlossomsDatin-1.mp4",
            )}
            title={homeCopy.videoTitle}
            poster={toLocalBlossomsAssetUrl(
              "https://www.blossoms.com/wp-content/uploads/2025/06/cherry-blossoms-dating-video.jpg",
            )}
            loading="lazy"
            muted
            loop
            playsinline
            preload="metadata"
          ></video>
        </div>
        <button
          class="video-hero__sound-toggle"
          type="button"
          data-home-video-toggle
          data-sound-label={homeCopy.videoSound}
          data-mute-label={homeCopy.videoMute}
          aria-pressed="false"
        >
          <span class="video-hero__sound-icon" aria-hidden="true">♪</span>
          <span data-home-video-toggle-label>{homeCopy.videoSound}</span>
        </button>
        <button
          class="video-hero__fullscreen-toggle"
          type="button"
          data-home-video-fullscreen
          data-fullscreen-label={homeCopy.videoFullscreen}
          data-exit-fullscreen-label={homeCopy.videoExitFullscreen}
          aria-pressed="false"
        >
          <span class="video-hero__fullscreen-icon" aria-hidden="true">⛶</span>
          <span data-home-video-fullscreen-label>{homeCopy.videoFullscreen}</span>
        </button>
      </div>
    </section>

    <section class="about shell">
      <div class="about__grid">
        <div class="about__content">
          <p class="section-kicker">{homeCopy.aboutKicker}</p>
          <h2>{homeCopy.aboutTitle}</h2>
          <p>{homeCopy.aboutBody}</p>
          <ul class="about__list">
            {
              homeCopy.aboutBullets.map((item) => (
                <li>
                  <strong>{item.label}:</strong> {item.detail}
                </li>
              ))
            }
          </ul>
          <div class="panel-actions">
            <a class="button-primary" href={localizePath("/about-us/", locale)}>{homeCopy.aboutPrimaryCta}</a>
            <a class="button-secondary" href={localizePath("/dating-safety/", locale)}>
              {homeCopy.aboutSecondaryCta}
            </a>
          </div>
        </div>
        <aside class="about__rail" aria-label="Trust highlights">
          <div class="about__seal">
            <span>{homeCopy.aboutSince}</span>
            <strong>1974</strong>
          </div>
          <div class="about__note">
            <p class="about__note-label">{homeCopy.aboutBuiltFor}</p>
            <p>{homeCopy.aboutBuiltForBody}</p>
          </div>
          <div class="about__stats">
            {
              homeCopy.aboutStats.map((item) => (
                <article>
                  <strong>{item.value}</strong>
                  <span>{item.detail}</span>
                </article>
              ))
            }
          </div>
        </aside>
      </div>
    </section>

    <section class="platform overview">
      <div class="overview-card">
        <div class="overview-card__media">
          <div class="image-card image-card--overview">
            <img
              src={toLocalBlossomsAssetUrl(
                "https://www.blossoms.com/wp-content/uploads/2025/02/blossoms-dating-site-philippines-members.jpg",
              )}
              alt="Asian online dating site in the Philippines"
              loading="lazy"
              decoding="async"
            />
            <div class="overview-card__caption">
              <span>{homeCopy.overviewCaptionKicker}</span>
              <strong>{homeCopy.overviewCaptionTitle}</strong>
            </div>
          </div>
        </div>

        <div class="overview-card__copy stack">
          <p class="section-kicker">{homeCopy.overviewKicker}</p>
          <h2 style="width:100%;">{homeCopy.overviewTitle}</h2>
          <div class="overview-card__body">
            {homeCopy.overviewBody.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>
      </div>
    </section>

    <section class="stats">
      <div class="shell stats__grid">
        {
          stats.map((stat) => (
            <article class="stat-card">
              <div class="stat-card__value">{stat.value}</div>
              <h3>{stat.label}</h3>
              <p>{stat.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="pillars shell">
      <div class="pillars__intro">
        <p class="section-kicker">{homeCopy.pillarsKicker}</p>
        <h2>{homeCopy.pillarsTitle}</h2>
      </div>

      <div class="pillars__tabs" data-pillars>
        {
          pillars.map((pillar, index) => (
            <input
              class="pillars__radio"
              type="radio"
              name="pillars-tab"
              id={`pillars-tab-${pillar.id}`}
              checked={index === 0}
            />
          ))
        }
        <div
          class="pillars__nav"
          role="tablist"
          aria-label={homeCopy.pillarsAriaLabel}
        >
          {
            pillars.map((pillar, index) => (
              <label
                class="pillars__tab"
                role="tab"
                id={`tab-${pillar.id}`}
                for={`pillars-tab-${pillar.id}`}
                aria-controls={`panel-${pillar.id}`}
                tabindex={index === 0 ? "0" : "-1"}
              >
                {pillar.tab}
              </label>
            ))
          }
        </div>

        <div class="pillars__panels">
          {
            pillars.map((pillar, index) => (
              <article
                class="pillar-panel"
                role="tabpanel"
                id={`panel-${pillar.id}`}
                aria-labelledby={`tab-${pillar.id}`}
                data-pillar-id={pillar.id}
              >
                <div class="stack">
                  <h3>{pillar.title}</h3>
                  <p>{pillar.body}</p>
                  {pillar.id === "using" && (
                    <div class="panel-actions">
                      <a
                        class="button-primary"
                        href="https://members.blossoms.com/register.php"
                        rel="nofollow"
                      >
                        {homeCopy.pillarsPrimaryCta}
                      </a>
                      <a
                        class="button-secondary"
                        href="https://members.blossoms.com/login.php"
                        rel="nofollow"
                      >
                        {ui.nav.login}
                      </a>
                    </div>
                  )}
                </div>
                <div class="pillar-panel__art" aria-hidden="true">
                  <div class={`orb orb--${pillar.id}`} />
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="stories shell">
      <div class="stories__intro">
        <p class="section-kicker">{homeCopy.storiesKicker}</p>
        <h2>{homeCopy.storiesTitle}</h2>
        <p>{homeCopy.storiesBody}</p>
        <div class="panel-actions">
          <a class="button-primary" href="/blog/">{homeCopy.storiesPrimaryCta}</a>
          <a class="button-secondary" href={localizePath("/frequently-asked-questions/", locale)}>
            {homeCopy.storiesSecondaryCta}
          </a>
        </div>
        <a
          class="store-badge"
          href="https://play.google.com/store/apps/details?id=com.cherryblossoms.dating&pli=1"
        >
          <img
            src={toLocalBlossomsAssetUrl(
              "https://www.blossoms.com/wp-content/uploads/2025/03/get-blossoms-asian-dating-app-in-play-store.png",
            )}
            alt="Get Blossoms Asian dating app in Play Store"
            loading="lazy"
            decoding="async"
          />
        </a>
      </div>

      <div class="stories__cards">
        <h3>{homeCopy.storiesHeading}</h3>
        {
          testimonials.map((story) => (
            <a class="story-card" href={story.href}>
              <img
                src={story.image}
                alt={story.name}
                loading="lazy"
                decoding="async"
              />
              <div class="story-card__body">
                <p>{story.quote}</p>
                <strong>{story.name}</strong>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="faq shell">
      <div class="faq__copy">
        <p class="section-kicker">{homeCopy.faqKicker}</p>
        <h2>{homeCopy.faqTitle}</h2>
        <p>{homeCopy.faqBody}</p>

        <div class="faq__items">
          {
            faqItems.map((item, index) => (
              <details class="faq-item" open={index === 0}>
                <summary>{item.question}</summary>
                <p>{item.answer}</p>
              </details>
            ))
          }
        </div>
      </div>

      <aside class="faq__media" aria-hidden="true">
        <img
          class="faq__image"
          src={toLocalBlossomsAssetUrl(
            "https://www.blossoms.com/wp-content/uploads/2025/02/Depositphotos_230654110_XL-scaled.jpg",
          )}
          alt="Asian online dating site Philippines"
          loading="lazy"
          decoding="async"
        />
      </aside>
    </section>

    <section class="locations shell" id="locations">
      <div class="locations__intro">
        <p class="section-kicker">{homeCopy.locationsKicker}</p>
        <h2>{homeCopy.locationsTitle}</h2>
        <p>{homeCopy.locationsSummary}</p>
      </div>

      <div class="locations__popular">
        {
          popularCities.map((city) => (
            <a class="locations__pill" href={city.href}>
              {city.label}
            </a>
          ))
        }
      </div>

      <details class="locations__disclosure">
        <summary>{homeCopy.locationsDisclosure}</summary>
        <div class="locations__grid">
          {
            locations.map((group) => (
              <article class="location-card">
                <h3>{group.province}</h3>
                <ul>
                  {group.cities.map((city) => (
                    <li>
                      <a href={city.href}>{city.label}</a>
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </details>
    </section>
  </div>

  <script is:inline>
    (() => {
      const video = document.getElementById("home-stream-player");
      const button = document.querySelector("[data-home-video-toggle]");
      const label = document.querySelector("[data-home-video-toggle-label]");
      const videoHero = document.querySelector(".video-hero");
      if (!(video instanceof HTMLVideoElement) || !button || !label || !videoHero) return;
      const soundLabel = button.getAttribute("data-sound-label") || label.textContent || "Sound";
      const muteLabel = button.getAttribute("data-mute-label") || "Mute";
      let isMuted = true;
      let isVideoVisible = false;

      const syncPlayback = async () => {
        try {
          if (isVideoVisible) {
            await video.play();
          } else {
            video.pause();
          }
        } catch (_error) {
          return;
        }
      };

      const syncButton = () => {
        button.setAttribute("aria-pressed", String(!isMuted));
        button.classList.toggle("is-active", !isMuted);
        label.textContent = isMuted ? soundLabel : muteLabel;
      };

      window.__homeVideoControls = {
        unmute: async () => {
          isMuted = false;
          video.muted = false;
          video.volume = 1;
          await video.play();
          syncButton();
        },
      };

      button.addEventListener("click", async () => {
        try {
          isMuted = !isMuted;
          video.muted = isMuted;
          if (!isMuted) {
            video.volume = 1;
            await video.play();
          }
          syncButton();
        } catch (_error) {
          isMuted = true;
          video.muted = true;
          syncButton();
        }
      });

      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            const [entry] = entries;
            isVideoVisible =
              Boolean(entry && entry.isIntersecting) &&
              (entry ? entry.intersectionRatio : 0) >= 0.35;
            syncPlayback();
          },
          {
            threshold: [0, 0.35, 0.65],
          },
        );

        observer.observe(videoHero);
      } else {
        isVideoVisible = true;
      }

      syncButton();
      syncPlayback();
    })();
  </script>

  <script is:inline>
    (() => {
      const frame = document.querySelector(".video-hero__frame");
      const button = document.querySelector("[data-home-video-fullscreen]");
      const label = document.querySelector("[data-home-video-fullscreen-label]");
      if (!frame || !button || !label) return;
      const fullscreenLabel =
        button.getAttribute("data-fullscreen-label") || label.textContent || "Full";
      const exitFullscreenLabel =
        button.getAttribute("data-exit-fullscreen-label") || "Exit";
      const syncButton = () => {
        const isFullscreen = document.fullscreenElement === frame;
        button.setAttribute("aria-pressed", String(isFullscreen));
        button.classList.toggle("is-active", isFullscreen);
        label.textContent = isFullscreen ? exitFullscreenLabel : fullscreenLabel;
      };

      button.addEventListener("click", async () => {
        try {
          if (document.fullscreenElement === frame) {
            await document.exitFullscreen();
          } else {
            await frame.requestFullscreen();
            if (
              window.__homeVideoControls &&
              typeof window.__homeVideoControls.unmute === "function"
            ) {
              await window.__homeVideoControls.unmute();
            }
          }
        } catch (_error) {
          return;
        }

        syncButton();
      });

      document.addEventListener("fullscreenchange", syncButton);
      syncButton();
    })();
  </script>

  <style>
    .home-redesign {
      --bg: #fff8f3;
      --surface: rgba(255, 255, 255, 0.82);
      --surface-strong: #ffffff;
      --line: rgba(125, 58, 66, 0.12);
      --ink: #24161c;
      --muted: #67545b;
      --accent: #df4b4b;
      --accent-deep: #a42a34;
      --accent-soft: #ffe0df;
      --gold: #e6ae62;
      background: rgba(255, 255, 255, 0.25);
      color: var(--ink);
    }

    .home-redesign a {
      color: inherit;
      text-decoration: none;
    }

    .shell {
      width: min(1200px, calc(100% - 2rem));
      margin: 0 auto;
    }

    .stack {
      display: grid;
      gap: 1rem;
    }

    .section-kicker,
    .eyebrow {
      margin: 0;
      color: var(--accent-deep);
      font-family:
        "Inter",
        system-ui,
        -apple-system,
        sans-serif;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
    }

    .section-kicker::before {
      content: "";
      display: inline-block;
      width: 1.6rem;
      height: 2px;
      background: linear-gradient(90deg, var(--accent-deep), var(--accent));
      border-radius: 1px;
      flex-shrink: 0;
    }

    #menu-item-25344 a {
      color: #ff0000;
    }

    .hero,
    .hero-section {
      position: relative;
      height: 60vh;
      min-height: min(52rem, 100vh - 70px);
      display: flex;
      align-items: center;
      overflow: clip;
      isolation: isolate;
      background:
        linear-gradient(
          90deg,
          rgba(255, 255, 255, 0.1) 0%,
          rgba(255, 244, 236, 0.08) 38%,
          rgba(255, 255, 255, 0.02) 100%
        ),
        url("//www.blossoms.com/wp-content/uploads/2025/02/blossoms-asian-dating-site-philippines-2.jpg")
          center center / cover no-repeat;
    }

    .hero__backdrop {
      display: none;
    }

    .hero__grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 2rem;
      align-items: end;
      padding: 4rem 0 4.5rem;
      position: relative;
      z-index: 1;
      height:100%;
    }

    .hero__copy {
      max-width: 42rem;
      color: #fff8f3;
      display: grid;
      gap: 1.25rem;
    }

    .hero h1 {
