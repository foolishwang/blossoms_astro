---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { listBlogPosts } from "../../../lib/posts";

const posts = await listBlogPosts();
---
<AdminLayout title="Posts | Blossoms Admin">
  <section class="admin-section">
    <div class="admin-section__header">
      <div>
        <p class="eyebrow">Content Manager</p>
        <h1>Blog posts</h1>
      </div>
      <a class="button" href="/admin/posts/new/">Create post</a>
    </div>

    <div class="table-card">
      <table>
        <thead>
          <tr>
            <th>Title</th>
            <th>Route</th>
            <th>Published</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {posts.map((post) => (
            <tr>
              <td>
                <strong>{post.title}</strong>
                <p>{post.excerpt.slice(0, 120)}</p>
              </td>
              <td>{post.route}</td>
              <td>{post.publishedAt ? new Date(post.publishedAt).toLocaleDateString("en-US") : "Draft"}</td>
              <td><a href={`/admin/posts/${post.id}/`}>Edit</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</AdminLayout>

<style>
  .admin-section { display: grid; gap: 1.25rem; }
  .admin-section__header {
    display: flex; justify-content: space-between; align-items: end; gap: 1rem;
  }
  .eyebrow {
    margin: 0 0 0.55rem; color: #a42a34; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase;
  }
  h1 { margin: 0; font: 700 clamp(2rem, 5vw, 3.6rem)/0.95 Raleway, serif; letter-spacing: -0.05em; }
  .button, tbody a {
    display: inline-flex; align-items: center; justify-content: center; padding: 0.9rem 1.15rem; border-radius: 999px;
    background: linear-gradient(135deg, #c72d39 0%, #e34c55 100%); color: #fff; text-decoration: none; font-weight: 700;
  }
  .table-card {
    overflow: auto; border: 1px solid rgba(125,58,66,.12); border-radius: 1.5rem; background: rgba(255,255,255,.94); box-shadow: 0 1.1rem 2.6rem rgba(121,57,67,.08);
  }
  table { width: 100%; border-collapse: collapse; min-width: 52rem; }
  th, td { padding: 1rem 1.1rem; text-align: left; vertical-align: top; border-bottom: 1px solid rgba(125,58,66,.08); }
  th { font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; color: #7f6169; }
  td p { margin: 0.35rem 0 0; color: #6c5860; line-height: 1.6; }
</style>
