---
import BlogPostPage from "../../components/blog/BlogPostPage.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import global from "../../data/global.json";
import { listBlogPosts, type BlogPostRecord } from "../../lib/posts";
import {
  buildPostContent,
  estimateReadingMinutes,
  extractFirstImage,
  extractHeadings,
  mapRelatedPost,
} from "../../lib/blog-page";
import {
  toLocalBlossomsAssetUrl,
  toRelativeSiteUrl,
} from "../../lib/url-utils";
import { buildBlogPostingSchema, buildBreadcrumbSchema } from "../../lib/seo";
import { DEFAULT_LOCALE } from "../../lib/i18n";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await listBlogPosts();

  return posts.map((post) => ({
    params: {
      slug: post.route.replace(/^\/blog\//, "").replace(/\/$/, ""),
    },
    props: {
      post,
      relatedPosts: posts
        .filter((entry) => entry.route !== post.route)
        .slice(0, 3)
        .map(mapRelatedPost),
    },
  }));
}

const { post, relatedPosts } = Astro.props as {
  post: BlogPostRecord;
  relatedPosts: ReturnType<typeof mapRelatedPost>[];
};

const title = post.seoTitle || `${post.title} | Cherry Blossoms`;
const description =
  post.seoDescription ||
  post.excerpt ||
  post.description ||
  "Asian dating advice, relationship guidance, and Filipina dating insights from Cherry Blossoms.";
const featuredImage = toLocalBlossomsAssetUrl(
  post.featuredImageUrl || extractFirstImage(post.contentHtml),
);
const postContentHtml = buildPostContent(post.contentHtml, featuredImage || "");
const postHeadings = extractHeadings(postContentHtml);
const readingMinutes = estimateReadingMinutes(post.contentHtml);
const schema = [
  buildBlogPostingSchema({
    title,
    description,
    url: post.route,
    image: featuredImage,
    datePublished: post.publishedAt,
    dateModified: post.updatedAt,
  }),
  buildBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Blog", url: "/blog/" },
    { name: post.title, url: post.route },
  ]),
];
---

<SiteLayout
  title={title}
  description={description}
  canonical={toRelativeSiteUrl(post.route)}
  bodyClass={global.bodyClass}
  global={global}
  locale={DEFAULT_LOCALE}
  showLanguageSwitcher={false}
  seo={{
    title,
    description,
    ogType: "article",
    ogTitle: post.ogTitle || title,
    ogDescription: post.ogDescription || description,
    ogImage: featuredImage || undefined,
    twitterTitle: post.twitterTitle || title,
    twitterDescription: post.twitterDescription || description,
    schema,
  }}
>
  <BlogPostPage
    title={title}
    description={description}
    featuredImage={featuredImage}
    publishedAt={post.publishedAt}
    readingMinutes={readingMinutes}
    postHeadings={postHeadings}
    postContentHtml={postContentHtml}
    relatedPosts={relatedPosts}
  />
</SiteLayout>
