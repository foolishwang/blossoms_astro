---
import routes from "../data/routes.json";
import global from "../data/global.json";
import SiteLayout from "../layouts/SiteLayout.astro";
import { normalizeInternalHrefHtml, toRelativeSiteUrl } from "../lib/url-utils";
import { getBlogPostByRoute, listBlogPosts } from "../lib/posts";
import {
  buildBreadcrumbSchema,
  buildFaqSchema,
  buildWebPageSchema,
} from "../lib/seo";

const BLOSSOMS_ORIGIN = "https://www.blossoms.com";
export const prerender = false;

const pathname = new URL(Astro.request.url).pathname;
const currentRoute = pathname.endsWith("/") ? pathname : `${pathname}/`;
const routeEntry = routes.find((route) => route.route === currentRoute) || null;
const dbPost =
  currentRoute.startsWith("/blog/") && currentRoute !== "/blog/"
    ? await getBlogPostByRoute(currentRoute)
    : null;
const entry = dbPost
  ? {
      route: dbPost.route,
      link: dbPost.route,
      kind: dbPost.kind,
      title: dbPost.title,
      excerptText: dbPost.excerpt,
      description: dbPost.description,
      content: dbPost.contentHtml,
      date: dbPost.publishedAt,
      modified: dbPost.updatedAt,
      seo: {
        title: dbPost.seoTitle,
        description: dbPost.seoDescription,
        ogTitle: dbPost.ogTitle,
        ogDescription: dbPost.ogDescription,
        twitterTitle: dbPost.twitterTitle,
        twitterDescription: dbPost.twitterDescription,
      },
    }
  : routeEntry;

const notFound = !entry;
if (notFound) {
  Astro.response.status = 404;
}
const safeEntry = entry || {
  route: currentRoute,
  link: currentRoute,
  kind: "page",
  title: "Page Not Found",
  excerptText: "",
  description: "",
  content:
    "<h1>Page not found</h1><p>The requested page could not be found.</p>",
  seo: {
    title: "Page Not Found",
    description: "",
  },
};

const title = safeEntry.title;
const description = safeEntry.excerptText || global.siteTitle;
const isBlogIndex = safeEntry.route === "/blog/";
const isBlogPost = safeEntry.kind === "post";

function absolutizeBlossomsAssets(content = "") {
  return content
    .replaceAll(
      'src="/wp-content/uploads/',
      `src="${BLOSSOMS_ORIGIN}/wp-content/uploads/`,
    )
    .replaceAll(
      "src='/wp-content/uploads/",
      `src='${BLOSSOMS_ORIGIN}/wp-content/uploads/`,
    )
    .replaceAll(
      'href="/wp-content/uploads/',
      `href="${BLOSSOMS_ORIGIN}/wp-content/uploads/`,
    )
    .replaceAll(
      "href='/wp-content/uploads/",
      `href='${BLOSSOMS_ORIGIN}/wp-content/uploads/`,
    )
    .replaceAll(
      'poster="/wp-content/uploads/',
      `poster="${BLOSSOMS_ORIGIN}/wp-content/uploads/`,
    )
    .replaceAll(
      "poster='/wp-content/uploads/",
      `poster='${BLOSSOMS_ORIGIN}/wp-content/uploads/`,
    )
    .replaceAll(
      "url('/wp-content/uploads/",
      `url('${BLOSSOMS_ORIGIN}/wp-content/uploads/`,
    )
    .replaceAll(
      'url("/wp-content/uploads/',
      `url("${BLOSSOMS_ORIGIN}/wp-content/uploads/`,
    )
    .replaceAll(
      "url(/wp-content/uploads/",
      `url(${BLOSSOMS_ORIGIN}/wp-content/uploads/`,
    )
    .replace(/(?<!:)\/\/www\.blossoms\.com\//g, "https://www.blossoms.com/");
}

function decodeHtml(value = "") {
  return value
    .replaceAll("&#038;", "&")
    .replaceAll("&#8211;", "–")
    .replaceAll("&#8217;", "'")
    .replaceAll("&#8220;", '"')
    .replaceAll("&#8221;", '"')
    .replaceAll("&#8230;", "...")
    .replaceAll("&amp;", "&")
    .replaceAll("&quot;", '"')
    .replaceAll("&#039;", "'");
}

function stripTags(value = "") {
  return decodeHtml(
    value
      .replace(/<[^>]+>/g, " ")
      .replace(/\s+/g, " ")
      .trim(),
  );
}

function slugify(value = "") {
  return value
    .toLowerCase()
    .replace(/&amp;/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

function extractFirstImage(content = "") {
  const pictureMatch = absolutizeBlossomsAssets(content).match(
    /<img[^>]+src="([^"]+)"/i,
  );
  return pictureMatch?.[1] || "";
}

function removeLeadFigure(content = "", featuredImage = "") {
  if (!featuredImage) return content;
  return content.replace(
    new RegExp(
      `<figure[^>]*>[\\s\\S]*?<img[^>]+src=["']${featuredImage.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}["'][\\s\\S]*?<\\/figure>\\s*`,
      "i",
    ),
    "",
  );
}

function addHeadingAnchors(content = "") {
  return content.replace(
    /<h([23])([^>]*)>([\s\S]*?)<\/h\1>/gi,
    (match, level, attrs, inner) => {
      if (/id=/.test(attrs)) return match;
      const text = stripTags(inner);
      const id = slugify(text);
      if (!id) return match;
      return `<h${level}${attrs} id="${id}">${inner}</h${level}>`;
    },
  );
}

function upgradeNumberedLeadParagraphs(content = "") {
  return content.replace(
    /<p>\s*<strong>\s*((?:\d+|[A-Z])[\.\):]\s*[\s\S]*?)<\/strong>\s*<\/p>/gi,
    (_match, inner) => {
      const text = stripTags(inner).trim();
      if (!text || text.length > 140) return _match;
      return `<h2>${inner.trim()}</h2>`;
    },
  );
}

function extractHeadings(content = "") {
  return [
    ...content.matchAll(/<h([23])[^>]*id="([^"]+)"[^>]*>([\s\S]*?)<\/h\1>/gi),
  ].map((match) => ({
    level: Number(match[1]),
    id: match[2],
    text: stripTags(match[3]),
  }));
}

function estimateReadingMinutes(content = "") {
  const words = stripTags(content).split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 220));
}

function stripNonContentMarkup(content = "") {
  return content
    .replace(/<style[\s\S]*?<\/style>/gi, "")
    .replace(/<script[\s\S]*?<\/script>/gi, "")
    .replace(/<svg[\s\S]*?<\/svg>/gi, "");
}

function extractBackgroundImage(content = "") {
  const match = absolutizeBlossomsAssets(content).match(
    /background-image:url\(['"]?([^'")]+)['"]?\)/i,
  );
  return match?.[1] || "";
}

function extractParagraphs(content = "") {
  return [...stripNonContentMarkup(content).matchAll(/<p[^>]*>([\s\S]*?)<\/p>/gi)]
    .map((match) => stripTags(match[1]))
    .map((text) => text.trim())
    .filter((text) => text.length > 60);
}

function extractListItems(content = "") {
  return [...stripNonContentMarkup(content).matchAll(/<li[^>]*>([\s\S]*?)<\/li>/gi)]
    .map((match) => stripTags(match[1]))
    .map((text) => text.trim())
    .filter(Boolean);
}

function extractSemanticBlocks(content = "", limit = 12) {
  return [...stripNonContentMarkup(content).matchAll(/<(h2|h3|p|ul|ol)[^>]*>[\s\S]*?<\/\1>/gi)]
    .map((match) => match[0].trim())
    .filter((block) => stripTags(block).trim().length > 0)
    .slice(0, limit)
    .join("\n");
}

function extractStatCards(content = "") {
  return [...content.matchAll(/<circle>\s*<h5>([\s\S]*?)<\/h5>\s*<\/circle>[\s\S]*?<h3[^>]*>([\s\S]*?)<\/h3>[\s\S]*?<p[^>]*>([\s\S]*?)<\/p>/gi)]
    .slice(0, 3)
    .map((match) => ({
      value: stripTags(match[1]),
      label: stripTags(match[2]),
      detail: stripTags(match[3]),
    }));
}

function extractFaqItems(content = "") {
  const sanitized = stripNonContentMarkup(content);
  const questions = [
    ...sanitized.matchAll(
      /<span[^>]*class="[^"]*kt-blocks-accordion-title[^"]*"[^>]*>([\s\S]*?)<\/span>/gi,
    ),
  ].map((match) => stripTags(match[1]));
  const answers = [
    ...sanitized.matchAll(
      /<div class="kt-accordion-panel-inner"[^>]*>([\s\S]*?)<\/div>\s*<\/div>/gi,
    ),
  ].map((match) => stripTags(stripNonContentMarkup(match[1])));

  return questions
    .map((question, index) => ({
      question,
      answer: answers[index] || "",
      id: slugify(question) || `faq-${index + 1}`,
    }))
    .filter((item) => item.question && item.answer);
}

function getFaqCategory(question = "") {
  const normalized = decodeHtml(question).toLowerCase();

  if (
    /site called|what is filipino dating|filipino dating on blossoms|exclusively cater|blossoms dating legit|site work|pinays|mail-order bride/i.test(
      normalized,
    )
  ) {
    return "About Blossoms";
  }

  if (
    /member and a subscriber|free|catch|login|password|log out|set up a profile|pay to set up a profile|age restrictions|mobile device|mobile app/i.test(
      normalized,
    )
  ) {
    return "Account & Membership";
  }

  if (
    /profile|photo|username|personal information|relationship status|job|education|children|married individuals|transgender/i.test(
      normalized,
    )
  ) {
    return "Profile & Identity";
  }

  if (
    /search|specific member|search results|filter|refine my matches|favorite|last online/i.test(
      normalized,
    )
  ) {
    return "Search & Matching";
  }

  if (
    /contact another member|reply|copy and paste|receive messages|stop receiving messages|message i sent|delete messages|conversation|responding to my messages|phone number|social media/i.test(
      normalized,
    )
  ) {
    return "Messaging";
  }

  if (
    /cost to subscribe|how can i pay|credit card|subscription|renewed automatically|refund/i.test(
      normalized,
    )
  ) {
    return "Billing & Subscription";
  }

  if (
    /report someone|block someone|verify my identity|safety tips|verification process|fake profile|privacy|guidelines|rules for communication|protect my personal information|trust the information/i.test(
      normalized,
    )
  ) {
    return "Safety & Trust";
  }

  if (
    /technical issues|bugs|customer support|helpline|forgot my password|not receiving any messages|can.t upload a photo|logged out|unable to access|displaying incorrectly|hacked or compromised|site\/app/i.test(
      normalized,
    )
  ) {
    return "Technical Help";
  }

  return "More Questions";
}

function splitLabelledListItem(item = "") {
  const decoded = decodeHtml(item).replace(/\u00a0/g, " ").replace(/\s+/g, " ").trim();
  const match = decoded.match(/^([^:]+):\s*(.+)$/);
  if (!match) {
    return { label: decoded, detail: "" };
  }
  return {
    label: match[1].trim(),
    detail: match[2].trim(),
  };
}

const featuredImage = isBlogPost
  ? extractFirstImage(safeEntry.content || "")
  : "";
const postContentHtml = isBlogPost
  ? addHeadingAnchors(
      absolutizeBlossomsAssets(
        normalizeInternalHrefHtml(
          upgradeNumberedLeadParagraphs(
            removeLeadFigure(safeEntry.content || "", featuredImage),
          ),
        ),
      ),
    )
  : "";
const normalizedContent = isBlogPost
  ? postContentHtml
  : absolutizeBlossomsAssets(normalizeInternalHrefHtml(safeEntry.content));
const postHeadings = isBlogPost ? extractHeadings(postContentHtml) : [];
const readingMinutes = isBlogPost
  ? estimateReadingMinutes(safeEntry.content || "")
  : 0;
const isAboutPage = !isBlogPost && !isBlogIndex && safeEntry.route === "/about-us/";
const aboutImages = isAboutPage
  ? [...new Set([...absolutizeBlossomsAssets(safeEntry.content || "").matchAll(/<img[^>]+src="([^"]+)"/gi)].map((match) => match[1]))]
      .filter((image) => !image.includes("medium-shot-smiley-woman-outdoors-682x1024.jpg"))
      .slice(0, 4)
  : [];
const aboutHeadings = isAboutPage
  ? [...stripNonContentMarkup(safeEntry.content || "").matchAll(/<h([2-3])[^>]*>([\s\S]*?)<\/h\1>/gi)]
      .map((match) => stripTags(match[2]))
      .filter(Boolean)
      .slice(0, 4)
  : [];
const aboutParagraphs = isAboutPage ? extractParagraphs(safeEntry.content || "") : [];
const aboutStats = isAboutPage
  ? [
      { value: "1974", label: "Founded", detail: "Started as Rainbow Ridge before becoming Cherry Blossoms online." },
      { value: "50+", label: "Years", detail: "Decades of matchmaking history across pen-pal, web, and mobile eras." },
      { value: "Global", label: "Reach", detail: "Built to connect international members with Filipina and Asian singles." },
    ]
  : [];
const aboutMilestones = isAboutPage
  ? [
      {
        year: "1974",
        title: "Founded as Rainbow Ridge",
        detail:
          aboutParagraphs.find((paragraph) => /1974|Rainbow Ridge/i.test(paragraph)) ||
          "The company began long before swipe-era dating, with a cross-border matchmaking model built on correspondence and real introductions.",
      },
      {
        year: "Early web",
        title: "From pen-pal era to digital matchmaking",
        detail:
          aboutParagraphs.find((paragraph) => /internet|online|web/i.test(paragraph)) ||
          "Blossoms adapted its model for the web without abandoning the human-centered approach that made it credible in the first place.",
      },
      {
        year: "Today",
        title: "A legacy brand still in motion",
        detail:
          aboutParagraphs.find((paragraph) => /mobile|today|platform|community/i.test(paragraph)) ||
          "The platform continues evolving across mobile, moderation, and discovery tools while staying anchored in trust and long-term intent.",
      },
    ]
  : [];
const aboutPrinciples = isAboutPage
  ? [
      "Longevity matters when trust is the product.",
      "Real introductions beat disposable engagement loops.",
      "Human moderation and integrity still matter in modern dating.",
      "The brand evolves, but the promise stays simple: meaningful connection.",
    ]
  : [];
const aboutBodyHtml = isAboutPage
  ? absolutizeBlossomsAssets(
      normalizeInternalHrefHtml(extractSemanticBlocks(safeEntry.content || "", 18)),
    )
  : "";
const isFaqPage =
  !isBlogPost &&
  !isBlogIndex &&
  safeEntry.route === "/frequently-asked-questions/";
const faqHeroImage = isFaqPage
  ? extractBackgroundImage(safeEntry.content || "") || extractFirstImage(safeEntry.content || "")
  : "";
const faqItems = isFaqPage ? extractFaqItems(safeEntry.content || "") : [];
const faqCategoryOrder = [
  "About Blossoms",
  "Account & Membership",
  "Profile & Identity",
  "Search & Matching",
  "Messaging",
  "Billing & Subscription",
  "Safety & Trust",
  "Technical Help",
  "More Questions",
];
const faqGroups = isFaqPage
  ? faqCategoryOrder
      .map((name) => ({
        name,
        items: faqItems.filter((item) => getFaqCategory(item.question) === name),
      }))
      .filter((group) => group.items.length > 0)
  : [];
const faqFeatured = isFaqPage
  ? [
      /legit/i,
      /site work/i,
      /member and a subscriber/i,
      /cost to subscribe/i,
      /report someone/i,
      /technical issues/i,
    ]
      .map((pattern) => faqItems.find((item) => pattern.test(decodeHtml(item.question))))
      .filter(Boolean)
      .filter((item, index, items) => items.findIndex((entry) => entry?.id === item?.id) === index)
  : [];
const faqIntroParagraphs = isFaqPage
  ? [
      faqItems.find((item) => /site work/i.test(decodeHtml(item.question)))?.answer,
      faqItems.find((item) => /privacy|report someone|verify my identity/i.test(decodeHtml(item.question)))?.answer,
    ].filter(Boolean)
  : [];
const isDatingSafetyPage =
  !isBlogPost &&
  !isBlogIndex &&
  safeEntry.route === "/dating-safety/";
const safetyHeroImage = isDatingSafetyPage
  ? extractBackgroundImage(safeEntry.content || "") || extractFirstImage(safeEntry.content || "")
  : "";
const safetyParagraphs = isDatingSafetyPage ? extractParagraphs(safeEntry.content || "") : [];
const safetyListItems = isDatingSafetyPage ? extractListItems(safeEntry.content || "") : [];
const safetyPrinciples = isDatingSafetyPage
  ? [
      {
        title: "Never send money",
        body:
          safetyParagraphs.find((paragraph) => /send money|financial information/i.test(paragraph)) ||
          "If someone you met online asks for money, banking details, or urgent financial help, stop the interaction immediately.",
      },
      {
        title: "Protect your identity",
        body:
          safetyParagraphs.find((paragraph) => /personal information|full name|address/i.test(paragraph)) ||
          "Keep sensitive information private until trust is real and verified, not just emotionally persuasive.",
      },
      {
        title: "Stay on-platform first",
        body:
          safetyParagraphs.find((paragraph) => /Staying on the site|staying on Blossoms Dating/i.test(paragraph)) ||
          "Platform messaging gives you reporting tools, moderation support, and a safer boundary while trust is still being established.",
      },
      {
        title: "Report suspicious behavior",
        body:
          safetyParagraphs.find((paragraph) => /report them|Support Team|law enforcement/i.test(paragraph)) ||
          "Fraud, harassment, impersonation, and coercive behavior should be reported early, not after escalation.",
      },
    ]
  : [];
const safetyRiskSignals = isDatingSafetyPage
  ? safetyListItems
      .filter((item) => /Scams and fraud|Harassment or abuse|Illegal activity|Catfishing|Spamming|Underage users/i.test(decodeHtml(item)))
      .slice(0, 6)
      .map(splitLabelledListItem)
  : [];
const safetyResourceCards = isDatingSafetyPage
  ? safetyListItems
      .filter((item) => /Support Team|Law enforcement|Hotline|Cybercrime|PNP|CFO|Gabriela|PTRAC/i.test(decodeHtml(item)))
      .slice(0, 7)
      .map(splitLabelledListItem)
  : [];
const safetyBodyHtml = isDatingSafetyPage
  ? absolutizeBlossomsAssets(
      normalizeInternalHrefHtml(extractSemanticBlocks(safeEntry.content || "", 18)),
    )
  : "";
const isLocationDatingPage =
  !isBlogPost &&
  !isBlogIndex &&
  /-online-dating-website\/$/.test(safeEntry.route);
const locationName = isLocationDatingPage
  ? title.replace(/\s+Dating Site$/i, "")
  : "";
const locationHeroImage = isLocationDatingPage
  ? extractBackgroundImage(safeEntry.content || "") || extractFirstImage(safeEntry.content || "")
  : "";
const locationParagraphs = isLocationDatingPage
  ? extractParagraphs(safeEntry.content || "")
  : [];
const locationListItems = isLocationDatingPage
  ? [...new Set(extractListItems(safeEntry.content || ""))].slice(0, 6)
  : [];
const locationStatCards = isLocationDatingPage
  ? extractStatCards(safeEntry.content || "")
  : [];
const locationBodyHtml = isLocationDatingPage
  ? absolutizeBlossomsAssets(
      normalizeInternalHrefHtml(extractSemanticBlocks(safeEntry.content || "")),
    )
  : "";
const runtimeBlogPosts = currentRoute.startsWith("/blog/")
  ? await listBlogPosts()
  : [];
const fallbackBlogPosts = routes
  .filter((route) => route.kind === "post")
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .map((post) => ({
    title: stripTags(post.title || ""),
    href: post.route,
    date: post.date,
    excerpt: stripTags(post.excerptText || post.excerpt || "").slice(0, 190),
    image: extractFirstImage(post.content || ""),
  }));
const blogPosts = isBlogIndex
  ? runtimeBlogPosts.length
    ? runtimeBlogPosts.map((post) => ({
        title: post.title,
        href: post.route,
        date: post.publishedAt || post.updatedAt,
        excerpt: stripTags(post.excerpt || post.description).slice(0, 190),
        image: post.featuredImageUrl || extractFirstImage(post.contentHtml),
      }))
    : fallbackBlogPosts
  : [];
const relatedPosts = isBlogPost
  ? runtimeBlogPosts.length
    ? runtimeBlogPosts
        .filter((post) => post.route !== safeEntry.route)
        .slice(0, 3)
        .map((post) => ({
          title: post.title,
          href: post.route,
          date: post.publishedAt || post.updatedAt,
          excerpt: stripTags(post.excerpt || post.description).slice(0, 150),
          image: post.featuredImageUrl || extractFirstImage(post.contentHtml),
        }))
    : fallbackBlogPosts
        .filter((post) => post.href !== safeEntry.route)
        .slice(0, 3)
  : [];
const pageSchema = (() => {
  if (isBlogPost || isBlogIndex) return [];

  const breadcrumbs = [
    { name: "Home", url: "/" },
    ...(safeEntry.route !== "/" ? [{ name: stripTags(safeEntry.title || title), url: safeEntry.route }] : []),
  ];

  if (isAboutPage) {
    return [
      buildWebPageSchema({
        title,
        description,
        url: safeEntry.route,
        type: "AboutPage",
      }),
      buildBreadcrumbSchema(breadcrumbs),
    ];
  }

  if (isFaqPage) {
    return [
      buildWebPageSchema({
        title,
        description,
        url: safeEntry.route,
        type: "FAQPage",
      }),
      buildFaqSchema(
        faqItems.slice(0, 20).map((item) => ({
          question: decodeHtml(item.question),
          answer: item.answer,
        })),
      ),
      buildBreadcrumbSchema(breadcrumbs),
    ];
  }

  if (isDatingSafetyPage) {
    return [
      buildWebPageSchema({
        title,
        description,
        url: safeEntry.route,
      }),
      buildBreadcrumbSchema(breadcrumbs),
    ];
  }

  if (isLocationDatingPage) {
    return [
      buildWebPageSchema({
        title,
        description,
        url: safeEntry.route,
      }),
      buildBreadcrumbSchema(breadcrumbs),
    ];
  }

  return [
    buildWebPageSchema({
      title,
      description,
      url: safeEntry.route,
    }),
    ...(safeEntry.route !== "/" ? [buildBreadcrumbSchema(breadcrumbs)] : []),
  ];
})();
const metaTitle = (() => {
  if (isAboutPage) return "About Cherry Blossoms | Asian Dating Brand Since 1974";
  if (isFaqPage) return "Asian Dating FAQs | Cherry Blossoms Help Center";
  if (isDatingSafetyPage) return "Asian Dating Safety Tips | Cherry Blossoms";
  if (isLocationDatingPage) return `${locationName} Filipina Dating Site | Cherry Blossoms`;
  return safeEntry.seo?.title || title;
})();
const metaDescription = (() => {
  if (isAboutPage) {
    return "Learn about Cherry Blossoms, an Asian dating brand serving international singles since 1974 with a focus on trust, long-term relationships, and meaningful connections.";
  }
  if (isFaqPage) {
    return "Find answers about Cherry Blossoms, Asian dating memberships, profiles, messaging, billing, safety, and technical support in one organized FAQ guide.";
  }
  if (isDatingSafetyPage) {
    return "Read Cherry Blossoms dating safety tips for Asian dating, including scam prevention, privacy protection, reporting suspicious behavior, and support resources.";
  }
  if (isLocationDatingPage) {
    return `Meet Filipina singles in ${locationName} with Cherry Blossoms. Explore ${locationName} Filipina dating, trusted profiles, and long-term relationship opportunities.`;
  }
  return safeEntry.seo?.description || safeEntry.excerptText || global.siteTitle;
})();
const resolvedSeo = {
  ...(safeEntry.seo || {}),
  title: metaTitle,
  description: metaDescription,
  ogTitle: safeEntry.seo?.ogTitle || metaTitle,
  ogDescription: safeEntry.seo?.ogDescription || metaDescription,
  twitterTitle: safeEntry.seo?.twitterTitle || metaTitle,
  twitterDescription: safeEntry.seo?.twitterDescription || metaDescription,
  schema: pageSchema,
};
---

<SiteLayout
  title={metaTitle}
  description={metaDescription}
  canonical={toRelativeSiteUrl(safeEntry.link)}
  bodyClass={global.bodyClass}
  global={global}
  seo={resolvedSeo}
>
  {
    isBlogIndex ? (
      <section class="blog-index">
        <div class="blog-index__shell">
          <div class="blog-index__hero">
            <p class="blog-index__eyebrow">Blossoms Journal</p>
            <h1>
              Dating advice, safety guidance, and real relationship stories.
            </h1>
            <p class="blog-index__lede">
              Browse practical posts on Filipina dating, long-distance
              relationships, cultural insights, and online dating safety from
              the Blossoms archive.
            </p>
          </div>

          <div class="blog-index__grid">
            {blogPosts.map((post) => (
              <article class="blog-card">
                {post.image && (
                  <a href={post.href} aria-label={`Read ${post.title}`}>
                    <img
                      src={post.image}
