---
import routes from "../data/routes.json";
import global from "../data/global.json";
import SiteLayout from "../layouts/SiteLayout.astro";
import {
  localizeBlossomsAssetHtml,
  normalizeInternalHrefHtml,
  toRelativeSiteUrl,
} from "../lib/url-utils";
import {
  buildBreadcrumbSchema,
  buildFaqSchema,
  buildWebPageSchema,
} from "../lib/seo";

export const prerender = false;

const pathname = new URL(Astro.request.url).pathname;
const currentRoute = pathname.endsWith("/") ? pathname : `${pathname}/`;
const routeEntry = routes.find((route) => route.route === currentRoute) || null;
const entry = routeEntry;

const notFound = !entry;
if (notFound) {
  Astro.response.status = 404;
}
const safeEntry = entry || {
  route: currentRoute,
  link: currentRoute,
  kind: "page",
  title: "Page Not Found",
  excerptText: "",
  description: "",
  content:
    "<h1>Page not found</h1><p>The requested page could not be found.</p>",
  seo: {
    title: "Page Not Found",
    description: "",
  },
};

const title = safeEntry.title;
const description = safeEntry.excerptText || global.siteTitle;

function absolutizeBlossomsAssets(content = "") {
  return localizeBlossomsAssetHtml(content);
}

function decodeHtml(value = "") {
  return value
    .replaceAll("&#038;", "&")
    .replaceAll("&#8211;", "–")
    .replaceAll("&#8217;", "'")
    .replaceAll("&#8220;", '"')
    .replaceAll("&#8221;", '"')
    .replaceAll("&#8230;", "...")
    .replaceAll("&amp;", "&")
    .replaceAll("&quot;", '"')
    .replaceAll("&#039;", "'");
}

function stripTags(value = "") {
  return decodeHtml(
    value
      .replace(/<[^>]+>/g, " ")
      .replace(/\s+/g, " ")
      .trim(),
  );
}

function slugify(value = "") {
  return value
    .toLowerCase()
    .replace(/&amp;/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

function extractFirstImage(content = "") {
  const pictureMatch = absolutizeBlossomsAssets(content).match(
    /<img[^>]+src="([^"]+)"/i,
  );
  return pictureMatch?.[1] || "";
}

function stripNonContentMarkup(content = "") {
  return content
    .replace(/<style[\s\S]*?<\/style>/gi, "")
    .replace(/<script[\s\S]*?<\/script>/gi, "")
    .replace(/<svg[\s\S]*?<\/svg>/gi, "");
}

function extractBackgroundImage(content = "") {
  const match = absolutizeBlossomsAssets(content).match(
    /background-image:url\(['"]?([^'")]+)['"]?\)/i,
  );
  return match?.[1] || "";
}

function extractParagraphs(content = "") {
  return [
    ...stripNonContentMarkup(content).matchAll(/<p[^>]*>([\s\S]*?)<\/p>/gi),
  ]
    .map((match) => stripTags(match[1]))
    .map((text) => text.trim())
    .filter((text) => text.length > 60);
}

function extractListItems(content = "") {
  return [
    ...stripNonContentMarkup(content).matchAll(/<li[^>]*>([\s\S]*?)<\/li>/gi),
  ]
    .map((match) => stripTags(match[1]))
    .map((text) => text.trim())
    .filter(Boolean);
}

function extractSemanticBlocks(content = "", limit = 12) {
  return [
    ...stripNonContentMarkup(content).matchAll(
      /<(h2|h3|p|ul|ol)[^>]*>[\s\S]*?<\/\1>/gi,
    ),
  ]
    .map((match) => match[0].trim())
    .filter((block) => stripTags(block).trim().length > 0)
    .slice(0, limit)
    .join("\n");
}

function extractStatCards(content = "") {
  return [
    ...content.matchAll(
      /<circle>\s*<h5>([\s\S]*?)<\/h5>\s*<\/circle>[\s\S]*?<h3[^>]*>([\s\S]*?)<\/h3>[\s\S]*?<p[^>]*>([\s\S]*?)<\/p>/gi,
    ),
  ]
    .slice(0, 3)
    .map((match) => ({
      value: stripTags(match[1]),
      label: stripTags(match[2]),
      detail: stripTags(match[3]),
    }));
}

function extractFaqItems(content = "") {
  const sanitized = stripNonContentMarkup(content);
  const questions = [
    ...sanitized.matchAll(
      /<span[^>]*class="[^"]*kt-blocks-accordion-title[^"]*"[^>]*>([\s\S]*?)<\/span>/gi,
    ),
  ].map((match) => stripTags(match[1]));
  const answers = [
    ...sanitized.matchAll(
      /<div class="kt-accordion-panel-inner"[^>]*>([\s\S]*?)<\/div>\s*<\/div>/gi,
    ),
  ].map((match) => stripTags(stripNonContentMarkup(match[1])));

  return questions
    .map((question, index) => ({
      question,
      answer: answers[index] || "",
      id: slugify(question) || `faq-${index + 1}`,
    }))
    .filter((item) => item.question && item.answer);
}

function getFaqCategory(question = "") {
  const normalized = decodeHtml(question).toLowerCase();

  if (
    /site called|what is filipino dating|filipino dating on blossoms|exclusively cater|blossoms dating legit|site work|pinays|mail-order bride/i.test(
      normalized,
    )
  ) {
    return "About Blossoms";
  }

  if (
    /member and a subscriber|free|catch|login|password|log out|set up a profile|pay to set up a profile|age restrictions|mobile device|mobile app/i.test(
      normalized,
    )
  ) {
    return "Account & Membership";
  }

  if (
    /profile|photo|username|personal information|relationship status|job|education|children|married individuals|transgender/i.test(
      normalized,
    )
  ) {
    return "Profile & Identity";
  }

  if (
    /search|specific member|search results|filter|refine my matches|favorite|last online/i.test(
      normalized,
    )
  ) {
    return "Search & Matching";
  }

  if (
    /contact another member|reply|copy and paste|receive messages|stop receiving messages|message i sent|delete messages|conversation|responding to my messages|phone number|social media/i.test(
      normalized,
    )
  ) {
    return "Messaging";
  }

  if (
    /cost to subscribe|how can i pay|credit card|subscription|renewed automatically|refund/i.test(
      normalized,
    )
  ) {
    return "Billing & Subscription";
  }

  if (
    /report someone|block someone|verify my identity|safety tips|verification process|fake profile|privacy|guidelines|rules for communication|protect my personal information|trust the information/i.test(
      normalized,
    )
  ) {
    return "Safety & Trust";
  }

  if (
    /technical issues|bugs|customer support|helpline|forgot my password|not receiving any messages|can.t upload a photo|logged out|unable to access|displaying incorrectly|hacked or compromised|site\/app/i.test(
      normalized,
    )
  ) {
    return "Technical Help";
  }

  return "More Questions";
}

function splitLabelledListItem(item = "") {
  const decoded = decodeHtml(item)
    .replace(/\u00a0/g, " ")
    .replace(/\s+/g, " ")
    .trim();
  const match = decoded.match(/^([^:]+):\s*(.+)$/);
  if (!match) {
    return { label: decoded, detail: "" };
  }
  return {
    label: match[1].trim(),
    detail: match[2].trim(),
  };
}

const normalizedContent = absolutizeBlossomsAssets(
  normalizeInternalHrefHtml(safeEntry.content),
);
const isAboutPage = safeEntry.route === "/about-us/";
const aboutImages = isAboutPage
  ? [
      ...new Set(
        [
          ...absolutizeBlossomsAssets(safeEntry.content || "").matchAll(
            /<img[^>]+src="([^"]+)"/gi,
          ),
        ].map((match) => match[1]),
      ),
    ]
      .filter(
        (image) =>
          !image.includes("medium-shot-smiley-woman-outdoors-682x1024.jpg"),
      )
      .slice(0, 4)
  : [];
const aboutHeadings = isAboutPage
  ? [
      ...stripNonContentMarkup(safeEntry.content || "").matchAll(
        /<h([2-3])[^>]*>([\s\S]*?)<\/h\1>/gi,
      ),
    ]
      .map((match) => stripTags(match[2]))
      .filter(Boolean)
      .slice(0, 4)
  : [];
const aboutParagraphs = isAboutPage
  ? extractParagraphs(safeEntry.content || "")
  : [];
const aboutStats = isAboutPage
  ? [
      {
        value: "1974",
        label: "Founded",
        detail:
          "Started as Rainbow Ridge before becoming Cherry Blossoms online.",
      },
      {
        value: "50+",
        label: "Years",
        detail:
          "Decades of matchmaking history across pen-pal, web, and mobile eras.",
      },
      {
        value: "Global",
        label: "Reach",
        detail:
          "Built to connect international members with Filipina and Asian singles.",
      },
    ]
  : [];
const aboutMilestones = isAboutPage
  ? [
      {
        year: "1974",
        title: "Founded as Rainbow Ridge",
        detail:
          aboutParagraphs.find((paragraph) =>
            /1974|Rainbow Ridge/i.test(paragraph),
          ) ||
          "The company began long before swipe-era dating, with a cross-border matchmaking model built on correspondence and real introductions.",
      },
      {
        year: "Early web",
        title: "From pen-pal era to digital matchmaking",
        detail:
          aboutParagraphs.find((paragraph) =>
            /internet|online|web/i.test(paragraph),
          ) ||
          "Blossoms adapted its model for the web without abandoning the human-centered approach that made it credible in the first place.",
      },
      {
        year: "Today",
        title: "A legacy brand still in motion",
        detail:
          aboutParagraphs.find((paragraph) =>
            /mobile|today|platform|community/i.test(paragraph),
          ) ||
          "The platform continues evolving across mobile, moderation, and discovery tools while staying anchored in trust and long-term intent.",
      },
    ]
  : [];
const aboutPrinciples = isAboutPage
  ? [
      "Longevity matters when trust is the product.",
      "Real introductions beat disposable engagement loops.",
      "Human moderation and integrity still matter in modern dating.",
      "The brand evolves, but the promise stays simple: meaningful connection.",
    ]
  : [];
const aboutBodyHtml = isAboutPage
  ? absolutizeBlossomsAssets(
      normalizeInternalHrefHtml(
        extractSemanticBlocks(safeEntry.content || "", 18),
      ),
    )
  : "";
const isFaqPage = safeEntry.route === "/frequently-asked-questions/";
const faqHeroImage = isFaqPage
  ? extractBackgroundImage(safeEntry.content || "") ||
    extractFirstImage(safeEntry.content || "")
  : "";
const faqItems = isFaqPage ? extractFaqItems(safeEntry.content || "") : [];
const faqCategoryOrder = [
  "About Blossoms",
  "Account & Membership",
  "Profile & Identity",
  "Search & Matching",
  "Messaging",
  "Billing & Subscription",
  "Safety & Trust",
  "Technical Help",
  "More Questions",
];
const faqGroups = isFaqPage
  ? faqCategoryOrder
      .map((name) => ({
        name,
        items: faqItems.filter(
          (item) => getFaqCategory(item.question) === name,
        ),
      }))
      .filter((group) => group.items.length > 0)
  : [];
const faqFeatured = isFaqPage
  ? [
      /legit/i,
      /site work/i,
      /member and a subscriber/i,
      /cost to subscribe/i,
      /report someone/i,
      /technical issues/i,
    ]
      .map((pattern) =>
        faqItems.find((item) => pattern.test(decodeHtml(item.question))),
      )
      .filter(Boolean)
      .filter(
        (item, index, items) =>
          items.findIndex((entry) => entry?.id === item?.id) === index,
      )
  : [];
const faqIntroParagraphs = isFaqPage
  ? [
      faqItems.find((item) => /site work/i.test(decodeHtml(item.question)))
        ?.answer,
      faqItems.find((item) =>
        /privacy|report someone|verify my identity/i.test(
          decodeHtml(item.question),
        ),
      )?.answer,
    ].filter(Boolean)
  : [];
const isDatingSafetyPage = safeEntry.route === "/dating-safety/";
const safetyHeroImage = isDatingSafetyPage
  ? extractBackgroundImage(safeEntry.content || "") ||
    extractFirstImage(safeEntry.content || "")
  : "";
const safetyParagraphs = isDatingSafetyPage
  ? extractParagraphs(safeEntry.content || "")
  : [];
const safetyListItems = isDatingSafetyPage
  ? extractListItems(safeEntry.content || "")
  : [];
const safetyPrinciples = isDatingSafetyPage
  ? [
      {
        title: "Never send money",
        body:
          safetyParagraphs.find((paragraph) =>
            /send money|financial information/i.test(paragraph),
          ) ||
          "If someone you met online asks for money, banking details, or urgent financial help, stop the interaction immediately.",
      },
      {
        title: "Protect your identity",
        body:
          safetyParagraphs.find((paragraph) =>
            /personal information|full name|address/i.test(paragraph),
          ) ||
          "Keep sensitive information private until trust is real and verified, not just emotionally persuasive.",
      },
      {
        title: "Stay on-platform first",
        body:
          safetyParagraphs.find((paragraph) =>
            /Staying on the site|staying on Blossoms Dating/i.test(paragraph),
          ) ||
          "Platform messaging gives you reporting tools, moderation support, and a safer boundary while trust is still being established.",
      },
      {
        title: "Report suspicious behavior",
        body:
          safetyParagraphs.find((paragraph) =>
            /report them|Support Team|law enforcement/i.test(paragraph),
          ) ||
          "Fraud, harassment, impersonation, and coercive behavior should be reported early, not after escalation.",
      },
    ]
  : [];
const safetyRiskSignals = isDatingSafetyPage
  ? safetyListItems
      .filter((item) =>
        /Scams and fraud|Harassment or abuse|Illegal activity|Catfishing|Spamming|Underage users/i.test(
          decodeHtml(item),
        ),
      )
      .slice(0, 6)
      .map(splitLabelledListItem)
  : [];
const safetyResourceCards = isDatingSafetyPage
  ? safetyListItems
      .filter((item) =>
        /Support Team|Law enforcement|Hotline|Cybercrime|PNP|CFO|Gabriela|PTRAC/i.test(
          decodeHtml(item),
        ),
      )
      .slice(0, 7)
      .map(splitLabelledListItem)
  : [];
const safetyBodyHtml = isDatingSafetyPage
  ? absolutizeBlossomsAssets(
      normalizeInternalHrefHtml(
        extractSemanticBlocks(safeEntry.content || "", 18),
      ),
    )
  : "";
const isLocationDatingPage = /-online-dating-website\/$/.test(safeEntry.route);
const locationName = isLocationDatingPage
  ? title.replace(/\s+Dating Site$/i, "")
  : "";
const locationHeroImage = isLocationDatingPage
  ? extractBackgroundImage(safeEntry.content || "") ||
    extractFirstImage(safeEntry.content || "")
  : "";
const locationParagraphs = isLocationDatingPage
  ? extractParagraphs(safeEntry.content || "")
  : [];
const locationListItems = isLocationDatingPage
  ? [...new Set(extractListItems(safeEntry.content || ""))].slice(0, 6)
  : [];
const locationStatCards = isLocationDatingPage
  ? extractStatCards(safeEntry.content || "")
  : [];
const locationBodyHtml = isLocationDatingPage
  ? absolutizeBlossomsAssets(
      normalizeInternalHrefHtml(extractSemanticBlocks(safeEntry.content || "")),
    )
  : "";
const pageSchema = (() => {
  const breadcrumbs = [
    { name: "Home", url: "/" },
    ...(safeEntry.route !== "/"
      ? [{ name: stripTags(safeEntry.title || title), url: safeEntry.route }]
      : []),
  ];

  if (isAboutPage) {
    return [
      buildWebPageSchema({
        title,
        description,
        url: safeEntry.route,
        type: "AboutPage",
      }),
      buildBreadcrumbSchema(breadcrumbs),
    ];
  }

  if (isFaqPage) {
    return [
      buildWebPageSchema({
        title,
        description,
        url: safeEntry.route,
        type: "FAQPage",
      }),
      buildFaqSchema(
        faqItems.slice(0, 20).map((item) => ({
          question: decodeHtml(item.question),
          answer: item.answer,
        })),
      ),
      buildBreadcrumbSchema(breadcrumbs),
    ];
  }

  if (isDatingSafetyPage) {
    return [
      buildWebPageSchema({
        title,
        description,
        url: safeEntry.route,
      }),
      buildBreadcrumbSchema(breadcrumbs),
    ];
  }

  if (isLocationDatingPage) {
    return [
      buildWebPageSchema({
        title,
        description,
        url: safeEntry.route,
      }),
      buildBreadcrumbSchema(breadcrumbs),
    ];
  }

  return [
    buildWebPageSchema({
      title,
      description,
      url: safeEntry.route,
    }),
    ...(safeEntry.route !== "/" ? [buildBreadcrumbSchema(breadcrumbs)] : []),
  ];
})();
const metaTitle = (() => {
  if (isAboutPage)
    return "About Cherry Blossoms | Asian Dating Brand Since 1974";
  if (isFaqPage) return "Asian Dating FAQs | Cherry Blossoms Help Center";
  if (isDatingSafetyPage) return "Asian Dating Safety Tips | Cherry Blossoms";
  if (isLocationDatingPage)
    return `${locationName} Filipina Dating Site | Cherry Blossoms`;
  return safeEntry.seo?.title || title;
})();
const metaDescription = (() => {
  if (isAboutPage) {
    return "Learn about Cherry Blossoms, an Asian dating brand serving international singles since 1974 with a focus on trust, long-term relationships, and meaningful connections.";
  }
  if (isFaqPage) {
    return "Find answers about Cherry Blossoms, Asian dating memberships, profiles, messaging, billing, safety, and technical support in one organized FAQ guide.";
  }
  if (isDatingSafetyPage) {
    return "Read Cherry Blossoms dating safety tips for Asian dating, including scam prevention, privacy protection, reporting suspicious behavior, and support resources.";
  }
  if (isLocationDatingPage) {
    return `Meet Filipina singles in ${locationName} with Cherry Blossoms. Explore ${locationName} Filipina dating, trusted profiles, and long-term relationship opportunities.`;
  }
  return (
    safeEntry.seo?.description || safeEntry.excerptText || global.siteTitle
  );
})();
const resolvedSeo = {
  ...(safeEntry.seo || {}),
  title: metaTitle,
  description: metaDescription,
  ogTitle: safeEntry.seo?.ogTitle || metaTitle,
  ogDescription: safeEntry.seo?.ogDescription || metaDescription,
  twitterTitle: safeEntry.seo?.twitterTitle || metaTitle,
  twitterDescription: safeEntry.seo?.twitterDescription || metaDescription,
  schema: pageSchema,
};
---

<SiteLayout
  title={metaTitle}
  description={metaDescription}
  canonical={toRelativeSiteUrl(safeEntry.link)}
  bodyClass={global.bodyClass}
  global={global}
  seo={resolvedSeo}
>
  {
    isAboutPage ? (
      <section class="about-page">
        <div class="about-shell">
          <section class="about-hero">
            <div class="about-hero__copy">
              <p class="about-eyebrow">About Blossoms</p>
              <p class="about-kicker">Since 1974</p>
              <h1>
                A long-running matchmaking brand that still treats trust as the
                product.
              </h1>
              <p class="about-lede">{aboutParagraphs[1] || description}</p>
              <div class="about-hero__summary">
                <p>
                  {aboutParagraphs[2] ||
                    "Blossoms spans the pen-pal era, the early web, and modern mobile dating without flattening the experience into disposable swipes."}
                </p>
                <p>
                  {aboutParagraphs[3] ||
                    "That history gives the brand a different posture: less hype, more proof, and a stronger expectation of sincerity."}
                </p>
              </div>
            </div>

            <div class="about-hero__media-stack">
              {aboutImages[1] && (
                <figure class="about-hero__media about-hero__media--portrait">
                  <img
                    src={aboutImages[1]}
                    alt="Blossoms Dating"
                    loading="eager"
                    decoding="async"
                  />
                </figure>
              )}
              <div class="about-hero__note">
                <p class="about-section-kicker">
                  What makes the brand distinct
                </p>
                <p>
                  Blossoms is not trying to look like a disposable dating app.
                  The differentiator is continuity: decades of operating
                  history, a clear international niche, and a more deliberate
                  approach to matching.
                </p>
              </div>
            </div>
          </section>

          <section class="about-ribbon">
            <div class="about-ribbon__intro">
              <p class="about-section-kicker">Brand markers</p>
              <h2>
                History, reputation, and cross-border focus are doing most of
                the work here.
              </h2>
            </div>
            <div class="about-stats">
              {aboutStats.map((stat) => (
                <article class="about-stat">
                  <p class="about-stat__value">{stat.value}</p>
                  <h3>{stat.label}</h3>
                  <p>{stat.detail}</p>
                </article>
              ))}
            </div>
          </section>

          <section class="about-history">
            <div class="about-history__heading">
              <p class="about-section-kicker">Timeline</p>
              <h2>
                {aboutHeadings[1] ||
                  "From early international introductions to a modern dating platform."}
              </h2>
            </div>
            <div class="about-timeline">
              {aboutMilestones.map((milestone) => (
                <article class="about-timeline__item">
                  <p class="about-timeline__year">{milestone.year}</p>
                  <h3>{milestone.title}</h3>
                  <p>{milestone.detail}</p>
                </article>
              ))}
            </div>
          </section>

          <section class="about-narrative">
            <article class="about-narrative__story">
              <p class="about-section-kicker">How Blossoms works as a brand</p>
              <h2>
                {aboutHeadings[2] ||
                  "A human-centered platform in a category full of noise."}
              </h2>
              {(aboutParagraphs.slice(4, 8).length
                ? aboutParagraphs.slice(4, 8)
                : [description]
              ).map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </article>

            <aside class="about-principles">
              <p class="about-section-kicker">Operating principles</p>
              <ul>
                {aboutPrinciples.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </aside>
          </section>

          {aboutImages.length > 2 && (
            <section class="about-gallery">
              <div class="about-gallery__copy">
                <p class="about-section-kicker">Visual language</p>
                <h2>
                  {aboutHeadings[3] ||
                    "A softer, more relational visual identity than most dating products."}
                </h2>
                <p>
                  The imagery is less about glossy performance and more about
                  warmth, sincerity, and real-world connection. That tone helps
                  the brand feel older, steadier, and more credible.
                </p>
              </div>
              <div class="about-gallery__grid">
                {aboutImages.slice(1, 4).map((image, index) => (
                  <figure
                    class:list={[
                      "about-gallery__item",
                      index === 0 && "about-gallery__item--large",
                    ]}
                  >
                    <img
                      src={image}
                      alt="Blossoms Dating history"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                ))}
              </div>
            </section>
          )}

          {aboutBodyHtml && (
            <section class="about-body">
              <div class="about-body__inner">
                <div class="about-body__heading">
                  <p class="about-section-kicker">Inside the company</p>
                  <h2>
                    The original company story, cleaned up for easier reading.
                  </h2>
                </div>
                <article class="about-richtext">
                  <Fragment set:html={aboutBodyHtml} />
                </article>
              </div>
            </section>
          )}

          <section class="about-cta">
            <div class="about-cta__copy">
              <p class="about-section-kicker">Blossoms today</p>
              <h2>
                Still designed for people who want something more intentional
                than endless casual swiping.
              </h2>
              <p>
                The brand advantage is not novelty. It is continuity, trust, and
                a clearer expectation that the people joining are there for
                something serious.
              </p>
            </div>
            <div class="faq-cta__actions">
              <a href="/frequently-asked-questions/">Browse FAQs</a>
              <a
                class="faq-cta__secondary"
                href="https://members.blossoms.com/register.php"
                target="_blank"
                rel="noreferrer noopener nofollow"
              >
                Join Blossoms
              </a>
            </div>
          </section>
        </div>
      </section>
    ) : isFaqPage ? (
      <section class="faq-page">
        <div class="faq-shell">
          <section
            class="faq-hero"
            style={
              faqHeroImage
